#!/bin/sh
# Mirror CI before pushing so `main` never goes red: formatting, types, build,
# and the SEO/launch gate (asset existence, canonical/sitemap drift, 404,
# placeholder links, stale Event schema, shipped TODOs…).
# Runs only on push (not every commit), so the extra seconds are infrequent.
# Bypass once with: git push --no-verify
npm run format:check && npm run check && npm run build && npm run audit
