---
// Readable, edge-aligned column for Markdown content pages (about, faq, terms,
// community-agreements, schedule). The rendered Markdown arrives via <slot/>, so
// its elements are styled with :global() below.
---

<div class="prose">
  <slot />
  <a href="/" class="prose-back">← Back home</a>
</div>

<style>
  .prose {
    width: var(--site-w);
    margin-left: var(--site-ml);
    max-width: 68ch;
    padding-top: clamp(3rem, 8vw, 5rem);
    padding-bottom: clamp(2rem, 7vw, 3rem);
  }

  .prose :global(h1) {
    margin-bottom: 1.25rem;
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 2rem 0 0.75rem;
  }

  .prose :global(p) {
    font-size: 1.0625rem;
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.25rem 1.25rem;
    line-height: 1.6;
  }

  .prose :global(li) {
    margin-bottom: 0.375rem;
  }

  .prose-back {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.9375rem;
    color: var(--muted);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    text-decoration-color: rgba(245, 244, 238, 0.25);
  }
  .prose-back:hover {
    color: var(--text);
    text-decoration-color: var(--text);
  }
  .prose-back:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>
