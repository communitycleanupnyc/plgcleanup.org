---
interface Props {
  navMode?: "ticker" | "static";
}
import { POUNDS_COLLECTED_DISPLAY } from "../data/stats";
const { navMode = "ticker" } = Astro.props;

const TICKER_TEXT = `${POUNDS_COLLECTED_DISPLAY} pounds and counting, this year alone! See which block is up next. →`;
---

<div class={`site-chrome ${navMode === "ticker" ? "compact" : "static-nav"}`} id="site-chrome">
  <div class="ticker-bar">
    <div class="ticker" id="ticker">
      <div class="ticker__viewport">
        <div class="ticker__track">
          <a href="/join" class="ticker__segment ticker__link">{TICKER_TEXT}</a>
        </div>
      </div>
      <!-- Control on the right, outside the scrolling area -->
      <button
        class="ticker__toggle"
        id="ticker-toggle"
        type="button"
        aria-pressed="false"
        aria-label="Play stats ticker"
      >
        <!-- play-circle (shown when paused) -->
        <svg
          class="ticker__icon ticker__icon--play"
          width="22"
          height="22"
          viewBox="2.25 2.25 19.5 19.5"
          fill="none"
          stroke="currentColor"
          stroke-width="0.75"
          aria-hidden="true"
        >
          <path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"></path>
          <path
            fill="currentColor"
            stroke="none"
            d="M15.91 11.672a.375.375 0 0 1 0 .656l-5.603 3.113a.375.375 0 0 1-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112Z"
          ></path>
        </svg>
        <!-- pause-circle (shown when playing) -->
        <svg
          class="ticker__icon ticker__icon--pause"
          width="22"
          height="22"
          viewBox="2.25 2.25 19.5 19.5"
          fill="none"
          stroke="currentColor"
          stroke-width="0.75"
          aria-hidden="true"
        >
          <path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"></path>
          <path stroke-width="1.5" stroke-linecap="square" d="M14.25 10v4M9.75 10v4"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Nav: logo left + links right (hidden in compact mode) -->
  <nav class="nav" id="main-nav" aria-label="Site navigation">
    <a href="/" class="nav-home" aria-label="Community Cleanup PLG — home">
      <svg
        class="site-logo"
        viewBox="0 0 333.75 362.83"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        ><path
          fill="currentColor"
          d="M13.34,131.12c-.16,1.43-.25,2.87-.25,4.33,0,25.68,24.91,46.5,55.65,46.5,12.97,0,24.9-3.72,34.36-9.94,3.64,1.61,7.45,2.98,11.42,4.04,2.3,11.4,5.85,29.29,7.39,38.52,4.59,27.34-.43,49.99-5.52,64.29l-4.9,16.2c9.79.95,26-3.23,34.17-8.25,6.59-4.05,18.37-13.83,24.27-18.83,14.15-11.96,23.27-13.83,23.27-13.83l-6.34-5.51c-18.33-17.96-12.56-45.48-6.29-62.55,9.19-.42,17.55-3.99,24.05-9.65,5.18,1.57,10.74,2.44,16.54,2.44,27.6,0,49.99-19.41,50.22-43.42,9.79-6.35,16.16-16.63,16.16-28.25,0-10.93-5.64-20.68-14.46-27.09,1.67-3.67,2.6-7.65,2.6-11.81,0-17.88-16.87-32.41-37.83-32.76-9.71-16.28-28.15-27.28-49.3-27.28-6.64,0-13,1.09-18.92,3.08-8.38-7.05-19.47-11.35-31.64-11.35-17.96,0-33.58,9.36-41.6,23.14-6.51-2.66-13.73-4.15-21.35-4.15-28.59,0-51.77,20.85-51.77,46.56,0,1.19.07,2.36.16,3.53C9.51,75.6,0,88.49,0,103.35c0,10.89,5.11,20.73,13.34,27.77ZM139.28,220.66c-4.86-4.31-7.29-31.96-8.61-41.97,1.82.12,3.64.2,5.5.2,5.7,0,11.23-.58,16.56-1.66-3.14,19.11-13.44,43.43-13.44,43.43ZM311.58,265.51c-.23,1.52-1.22,2.9-2.12,4.17-1.62,2.17-3.55,4.19-5.49,6.12-5.03,4.99-10.5,9.56-15.62,14.5-7.48,7.35-20.48,17.02-20.48,17.02,0,0,14.29-15.96,14.72-26.27.16-3.87-1.41-6.07-1.41-6.07,0,0,9.3-6.09,14.88-9.27.32-.18,2.04-1.18,2.31-1.33,1-.54,2.03-1.05,3.06-1.52,1.7-.77,3.59-1.48,5.41-1.64,1.07-.1,2.23-.02,3.16.39,1.52.65,1.74,2.41,1.58,3.89ZM333.25,253.68c-1.09,1.95-2.68,3.65-4.27,5.25-3.45,3.42-14.21,10.36-14.21,10.36,0,0,2.7-5.01,1.99-8.11-1.02-4.47-7.01-4.82-7.75-4.78,9.36-4.64,18.72-8.84,23.26-6.32.72.41,1.2,1.11,1.47,1.91.09.49-.21,1.16-.49,1.7ZM271.66,292.46c-7.55,15.13-19.31,27.94-32.55,38.33-25.22,19.73-56.89,29.79-88.65,31.67-7.92.5-16.01.52-23.93-.03-1.14-.07-3.56-.33-4.77-.42-.94-.09-2.2-.26-3.17-.37-2.93-.34-6.52-.92-9.44-1.48-.95-.17-2.15-.41-3.12-.64-.88-.19-2.26-.49-3.11-.69-.97-.26-3.74-.9-4.63-1.19-.78-.21-2.28-.66-3.07-.87-2.4-.73-5.17-1.65-7.56-2.52-1.94-.72-4.02-1.52-5.93-2.34-31.74-13.15-56.74-39.01-73.62-68.5,0,0,45.29,31.51,92.02,33.35,28.01,1.1,41.21-6.73,47.31-10.88,13.49-9.59,26.4-20.01,39.83-29.65,2.59-1.84,5.18-3.66,7.87-5.35,7.31-4.56,28.76-17.41,35.23-7.65.92,1.8-.2,3.74-1.35,5.26-2.33,2.95-5.64,5.32-8.93,7.19-.74.42-2.85,1.5-3.61,1.91-5.82,3.07-11.92,6.62-15.53,12.33-1.17,1.91-1.96,4.17-1.89,6.41h.69s30.66-11.76,65.13-32.19c6.65-3.94,21.86-11.86,28.97-14.77,3.76-1.46,9.05-3.4,12.96-2.51,1.57.31,3.78,1.78,3.78,1.78l-35.26,23.08c-9.6.49-13.77,5.61-24.16,19.96-3.76,5.19-11.33,15.73-15.17,17.75,2.12-.55,7.42-1,12.76-5.47,4.89-4.1,8.9-9.71,12.86-14.7,2.56-3.2,8.65-12.67,13.69-10.93,3.29,1.14-2.19,11.06-3.65,14.09Z"
        ></path></svg
      >
      <span class="nav-wordmark">Community Cleanup PLG</span>
    </a>
    <div class="nav-links">
      <a href="/about" class="nav-link">About</a>
      <a href="/faq" class="nav-link">FAQ</a>
      <span class="nav-divider" aria-hidden="true"></span>
      <a href="/join" class="nav-btn">Join</a>
    </div>
  </nav>
</div><!-- /.site-chrome -->

<div id="chrome-spacer" aria-hidden="true"></div>

<script>
  // Site chrome behavior: fill the scrolling ticker and show/hide the nav on
  // scroll. Coordinates the (sibling) menu button by id, which MobileMenu renders.
  const chrome = document.getElementById("site-chrome")!;
  const isStaticNav = chrome.classList.contains("static-nav");
  const menuBtn = document.getElementById("nav-menu-btn");

  // ── Ticker ──────────────────────────────────────────
  const ticker = document.getElementById("ticker")!;
  const tickerToggle = document.getElementById("ticker-toggle")!;
  const tickerTrack = ticker.querySelector(".ticker__track") as HTMLElement;
  const tickerViewport = ticker.querySelector(".ticker__viewport") as HTMLElement;

  // Clone segments until track fills 3× the viewport, then pin --seg-w.
  // Animates from translateX(0) → translateX(--seg-w) so the loop is
  // seamless at any viewport width, with natural inter-segment spacing.
  function fillTicker() {
    const template = tickerTrack.children[0] as HTMLElement;
    // Read geometry once, up front — never inside the loop below (reading a
    // dirtied layout after each appendChild is the forced-reflow thrash).
    const segW = template.offsetWidth;
    if (!segW) return;
    const target = tickerViewport.offsetWidth * 3;
    // How many segments fill 3× the viewport (+1 spare for a seamless loop),
    // minus what's already there — so a resize re-run adds nothing.
    const want = Math.ceil(target / segW) + 1;
    const needed = Math.max(0, want - tickerTrack.children.length);
    // Build the clones off-DOM, then attach in a single write (no reflow).
    const frag = document.createDocumentFragment();
    for (let i = 0; i < needed; i++) {
      const clone = template.cloneNode(true) as HTMLElement;
      clone.setAttribute("aria-hidden", "true");
      clone.setAttribute("tabindex", "-1");
      frag.appendChild(clone);
    }
    tickerTrack.appendChild(frag);
    tickerTrack.style.setProperty("--seg-w", segW + "px");
  }

  document.fonts.ready.then(fillTicker);
  new ResizeObserver(fillTicker).observe(tickerViewport);

  // Autoplay on load — only if user has no motion preference and ticker is shown
  if (!isStaticNav && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    ticker.classList.add("is-playing");
    tickerToggle.setAttribute("aria-pressed", "true");
    tickerToggle.setAttribute("aria-label", "Pause stats ticker");
  }

  tickerToggle.addEventListener("click", () => {
    const playing = ticker.classList.toggle("is-playing");
    tickerToggle.setAttribute("aria-pressed", String(playing));
    tickerToggle.setAttribute("aria-label", playing ? "Pause stats ticker" : "Play stats ticker");
    tickerToggle.classList.add("is-activated");
  });

  // ── Scroll behavior ─────────────────────────────────────────────
  if (isStaticNav) {
    // Static-nav pages: start visible, hide on scroll-down, reveal on scroll-up.
    let lastY = window.scrollY;
    let ticking = false;
    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            const y = window.scrollY;
            if (y > lastY && y > 8) {
              chrome.classList.add("is-hidden");
              menuBtn?.classList.add("is-nav-hidden");
            } else if (y < lastY) {
              chrome.classList.remove("is-hidden");
              menuBtn?.classList.remove("is-nav-hidden");
            }
            lastY = y;
            ticking = false;
          });
          ticking = true;
        }
      },
      { passive: true },
    );
  } else {
    // Ticker pages: compact in-flow at top → fixed+revealed on scroll-up past 25vh.
    const threshold = window.innerHeight * 0.25;
    let lastY = 0;
    let ticking = false;
    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            const y = window.scrollY;
            const scrollingDown = y > lastY;
            const pastThreshold = y > threshold;

            if (!pastThreshold) {
              if (chrome.classList.contains("is-fixed") && !chrome.dataset.leaving) {
                // Leaving is-fixed → compact: slide button out with chrome.
                // CSS switches button back to sticky once compact class is restored.
                chrome.dataset.leaving = "1";
                menuBtn?.classList.add("is-nav-hidden");
                chrome.classList.remove("is-revealed");
                chrome.addEventListener(
                  "transitionend",
                  () => {
                    delete chrome.dataset.leaving;
                    if (!chrome.classList.contains("is-revealed")) {
                      chrome.classList.add("no-transition");
                      chrome.classList.remove("is-fixed");
                      chrome.classList.add("compact");
                      void chrome.offsetHeight;
                      chrome.classList.remove("no-transition");
                      menuBtn?.classList.remove("is-nav-hidden");
                    }
                  },
                  { once: true },
                );
              }
              // else: already compact — position: sticky handles everything, no JS needed.
            } else if (scrollingDown) {
              chrome.classList.remove("is-revealed");
              menuBtn?.classList.add("is-nav-hidden");
            } else {
              menuBtn?.classList.remove("is-nav-hidden");
              delete chrome.dataset.leaving;
              if (!chrome.classList.contains("is-fixed")) {
                chrome.classList.add("no-transition");
                chrome.classList.remove("compact");
                chrome.classList.add("is-fixed");
                void chrome.offsetHeight;
                chrome.classList.remove("no-transition");
              }
              chrome.classList.add("is-revealed");
            }

            lastY = y;
            ticking = false;
          });
          ticking = true;
        }
      },
      { passive: true },
    );
  }
</script>
