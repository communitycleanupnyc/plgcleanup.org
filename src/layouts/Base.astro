---
interface Props {
    title?: string;
    description?: string;
    navMode?: "ticker" | "static";
}
const {
    title = "Community Cleanup PLG",
    description = "We clean Prospect Lefferts Gardens. No registration, all supplies included. Just show up.",
    navMode = "ticker",
} = Astro.props;

const TICKER_TEXT =
    "2,972.55 pounds and counting, this year alone! See which block is up next. →";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="theme-color" content="#14130F" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
        <link rel="apple-touch-icon" href="/images/logo.webp" />
        <link
            rel="preload"
            href="/fonts/HankenGrotesk.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link
            rel="preload"
            href="/fonts/Fraunces.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />

        <style is:global>
            @font-face {
                font-family: "Fraunces";
                src: url("/fonts/Fraunces.woff2") format("woff2-variations");
                font-weight: 100 900;
                font-display: swap;
            }
            @font-face {
                font-family: "Hanken Grotesk";
                src: url("/fonts/HankenGrotesk.woff2")
                    format("woff2-variations");
                font-weight: 100 900;
                font-display: swap;
            }

            :root {
                --bg: #000;
                --text: #E2E2E2;
                --muted: #292929; /* #9a988f; */
                --line: #3D3D3D;
                --brand: #63c9ea;
                --accent: #24CB71;
                --select: #eeb408;
                --edge: clamp(1.25rem, 5vw, 3rem);
                --ticker-bg: rgba(255, 255, 255, 0.75);
                --ticker-h: 3.3rem;
                --nav-h: 3.52rem;
                /* Round 6 additions */
                --btn-light: var(--text);
                --hover-radius: 0;
                --ticker-duration: 12s;
                /* Content column: width + derived left-offset for the 95→90vw breakout */
                --site-w: 94vw;
                --site-ml: calc(50% - var(--site-w) / 2);
            }

            *,
            *::before,
            *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            html {
                background: var(--bg);
            }

            ::selection {
                background: var(--accent);
                color: var(--bg);
            }
            ::-moz-selection {
                background: var(--accent);
                color: var(--bg);
            }

            mark {
                background: var(--select);
                color: var(--bg);
                padding: 0 0.15em;
            }

            body {
                font-family: "Hanken Grotesk", system-ui, sans-serif;
                font-variant-numeric: slashed-zero;
                background: var(--bg);
                color: var(--text);
                min-height: 100svh;
                display: flex;
                flex-direction: column;
                overflow-x: clip;
            }

            /* Inline links (no class) — underline flush with bg bottom, smooth hover */
            a:not([class]) {
                color: inherit;
                text-decoration: none;
                box-shadow: inset 0 -1.25px 0 0 var(--text);
                transition:
                    background-color 225ms ease,
                    color 225ms ease,
                    box-shadow 225ms ease;
            }
            a:not([class]):hover,
            a:not([class]):focus-visible {
                background-color: var(--accent);
                color: var(--bg);
                box-shadow: inset 0 -1.25px 0 0 var(--accent);
                outline: none;
            }

            .sr-only {
                position: absolute;
                width: 1px;
                height: 1px;
                padding: 0;
                margin: -1px;
                overflow: hidden;
                clip: rect(0, 0, 0, 0);
                white-space: nowrap;
                border: 0;
            }

            /* ── Ticker ─────────────────────────────────────── */

            /* ── Site chrome: static by default, scrolls with page ── */
            .site-chrome {
                background: var(--bg);
                z-index: 50;
            }
            /* Revealed state: fixed at top, slides in on scroll-up past threshold */
            .site-chrome.is-fixed {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                transform: translateY(-100%);
                transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            }
            .site-chrome.is-fixed.is-revealed {
                transform: translateY(0);
            }
            .site-chrome.no-transition {
                transition: none !important;
            }
            /* Spacer holds layout height while chrome is position:fixed (out of flow).
               Swap is net-zero: chrome exits flow (-nav-h) + spacer appears (+nav-h). */
            #chrome-spacer { height: 0; }
            .site-chrome.is-fixed + #chrome-spacer { height: var(--nav-h); }

            /* Static nav (join, about, faq, …): fixed at top, visible by default,
               slides away on scroll-down and back on scroll-up. */
            .site-chrome.static-nav {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                transform: translateY(0);
                transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            }
            .site-chrome.static-nav.is-hidden { transform: translateY(-100%); }
            .site-chrome.static-nav .ticker-bar { display: none; }
            .site-chrome.static-nav + #chrome-spacer { height: var(--nav-h); }

            /* Compact (at page top): ticker fills bar, nav links flush right, no logo.
               padding-inline centers the content at --site-w so the ticker left-edge
               and nav right-edge align exactly with the content column below. */
            .site-chrome.compact {
                display: flex;
                align-items: stretch;
                height: var(--nav-h);
                background: var(--bg);
                padding-inline: calc((100vw - var(--site-w)) / 2);
            }
            .site-chrome.compact .ticker-bar {
                flex: 0 0 50%;
                min-width: 0;
                background: none;
            }
            .site-chrome.compact .ticker {
                width: 100%;
                margin: 0;
                padding-left: 0;
                border-bottom: none;
                height: 100%;
            }
            .site-chrome.compact .nav {
                flex: 0 0 50%;
                height: var(--nav-h);
                padding: 0;
                justify-content: flex-end;
                background: none;
            }
            .site-chrome.compact .nav-home { display: none; }

            /* Full-bleed ticker wrapper (non-compact) */
            .ticker-bar {
                width: 100%;
                background: transparent;
            }

            .ticker {
                width: var(--site-w);
                margin-inline: auto;
                height: var(--ticker-h);
                display: flex;
                align-items: center;
            }

            .ticker__viewport {
                flex: 1;
                min-width: 0;
                overflow: hidden;
                position: relative;
                display: flex;
                align-items: center;
            }

            .ticker__track {
                display: flex;
                width: max-content;
                will-change: transform;
                font-size: 0.85rem;
                font-weight: 400;
                letter-spacing: 0.04em;
                color: var(--text);
                font-variant-numeric: tabular-nums slashed-zero;
                white-space: nowrap;
            }

            .ticker__segment {
                flex-shrink: 0;
                padding-right: clamp(2rem, 8vw, 6rem);
            }

            /* Continuous band: bg lives on the viewport (always fills full width) */
            .ticker__viewport {
                background: var(--muted);
                transition: background 0ms ease;
                cursor: pointer;
            }
            .ticker__viewport:hover {
                background: var(--accent);
            }
            .ticker__viewport:hover .ticker__link {
                color: var(--bg);
            }
            .ticker__link {
                display: inline-flex;
                align-items: center;
                text-decoration: none;
                color: var(--text);
                padding: 0.447rem 0.75em;
            }

            .ticker.is-playing .ticker__track {
                animation: ticker-rtl var(--ticker-duration) linear infinite;
            }

            @keyframes ticker-rtl {
                from { transform: translateX(0); }
                to   { transform: translateX(calc(-1 * var(--seg-w, 0px))); }
            }

            /* Control sits on the right, outside the scrolling area */
            .ticker__toggle {
                flex: none;
                display: grid;
                place-items: center;
                width: 1.65rem;
                height: 1.65rem;
                margin-left: 0.5rem;
                background: none;
                border: none;
                cursor: pointer;
                color: var(--muted);
                transition: color 225ms ease;
            }
            .ticker__toggle:hover,
            .ticker__toggle:focus-visible {
                color: var(--text);
            }
            .ticker__toggle:focus-visible {
                outline: 2px solid var(--brand);
                outline-offset: 2px;
                border-radius: 0;
            }

            /* Icon swap: show play-circle when paused, pause-circle when playing */
            .ticker__icon { width: 1.65rem; height: 1.65rem; }
            .ticker__icon--play path + path { fill: var(--text); }
            .ticker__icon--pause path + path { stroke: var(--text); stroke-width: 2; }
            .ticker__icon--pause {
                display: none;
            }
            .ticker.is-playing .ticker__icon--play {
                display: none;
            }
            .ticker.is-playing .ticker__icon--pause {
                display: block;
            }

            /* ── Nav ────────────────────────────────────────── */

            .nav {
                display: flex;
                justify-content: space-between;
                align-items: center;
                width: var(--site-w);
                margin-inline: auto;
                padding: 0;
                height: var(--nav-h);
                background: transparent;
            }

            .nav-home {
                display: inline-flex;
                align-items: center;
                text-decoration: none;
                color: var(--text);
                transition: color 225ms ease;
            }
            .nav-home:hover,
            .nav-home:focus-visible {
                color: var(--accent);
                outline: none;
            }

            .nav-wordmark {
                font-size: 1.1rem;
                font-weight: 350;
                letter-spacing: 0;
                margin-left: 0.963rem;
            }

            .site-logo {
                height: 2.75rem;
                width: auto;
                display: block;
                flex-shrink: 0;
            }

            .nav-links {
                display: flex;
                align-items: center;
                gap: 0;
            }

            .nav-divider {
                display: block;
                width: 1px;
                height: 1.926rem;
                background: var(--line);
                flex-shrink: 0;
                margin: 0 0.75rem;
            }

            .nav-link {
                display: inline-flex;
                align-items: center;
                line-height: 1;
                font-size: 1.1rem;
                font-weight: 350;
                letter-spacing: 0rem;
                text-transform: uppercase;
                color: var(--text);
                text-decoration: none;
                border-radius: var(--hover-radius);
                padding: 0.413rem 0.963rem;
                transition:
                    background-color 225ms ease,
                    color 225ms ease;
            }
            .nav-link:hover,
            .nav-link:focus-visible {
                background: var(--accent);
                color: var(--bg);
                outline: none;
            }

            .nav-btn {
                display: inline-flex;
                align-items: center;
                line-height: 1;
                font-size: 1.1rem;
                font-weight: 350;
                letter-spacing: 0rem;
                text-transform: uppercase;
                color: var(--bg);
                background: var(--btn-light);
                text-decoration: none;
                padding: 0.413rem 0.963rem;
                margin-left: 0;
                border-radius: 0;
                transition: background-color 225ms ease;
            }
            .nav-btn:hover,
            .nav-btn:focus-visible {
                background: var(--accent);
                outline: none;
            }

            /* ── Main ───────────────────────────────────────── */

            main {
                flex: 1;
                max-width: 900px;
                width: 100%;
                margin-inline: auto;
                /* padding-top removed — site-chrome is in-flow sticky */
            }

            /* ── Hero (home page) ───────────────────────────── */

            .hero {
                position: relative;
                width: var(--site-w);
                margin-left: var(--site-ml);
                padding-top: clamp(3rem, 8vw, 5rem);
                margin-bottom: clamp(14rem, 7vw, 3.5rem);
            }

            .hero-kicker {
                font-size: 0.6875rem;
                font-weight: 500;
                letter-spacing: 0.15em;
                text-transform: uppercase;
                color: var(--muted);
                margin-bottom: 0.875rem;
            }

            h1 {
                font-family: "Fraunces", Georgia, serif;
                font-size: clamp(6.25rem, 11vw, 6rem);
                font-weight: 700;
                line-height: 1.1;
                letter-spacing: -0.01em;
                font-optical-sizing: auto;
                font-variation-settings:
                    "SOFT" 50,
                    "WONK" 3;
                position: relative;
                z-index: 1;
            }

            .raccoon {
                position: absolute;
                z-index: 0;
                right: var(--edge);
                top: 85%;
                transform: translateY(-25%) rotate(-20deg);
                width: clamp(100px, 26vw, 148px);
                height: auto;
                pointer-events: none;
                user-select: none;
                opacity: 0.88;
            }

            @media (max-width: 380px) {
                .raccoon {
                    width: 100px;
                }
            }

            /* ── Next Cleanup grid ──────────────────────────── */

            .cleanup {
                display: grid;
                grid-template-columns: auto auto 1fr;
                column-gap: 0.5rem;
                row-gap: 0.4rem;
                width: fit-content;
                max-width: calc(100% - var(--edge) * 2);
                margin-inline: auto;
                align-items: center;
                text-align: left;
                margin-bottom: clamp(1.5rem, 5vw, 2.5rem);
            }

            .cleanup .span {
                grid-column: 2 / 4;
            }

            .cleanup .icon-cell {
                width: 18px;
                height: 18px;
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--muted);
                flex-shrink: 0;
            }
            .cleanup .icon-cell svg {
                width: 100%;
                height: 100%;
            }

            .cleanup a.icon-cell {
                text-decoration: none;
                border-radius: 0;
                transition: color 0.15s;
            }
            .cleanup a.icon-cell:hover {
                color: var(--brand);
            }
            .cleanup a.icon-cell:focus-visible {
                outline: 2px solid var(--accent);
                outline-offset: 3px;
            }

            /* Conversational sentence — sentence case, wraps gracefully */
            .cleanup-countdown {
                font-size: 0.9375rem;
                font-weight: 400;
                line-height: 1.5;
                color: var(--muted);
            }

            .cleanup-key {
                font-size: 0.9375rem;
                font-weight: 600;
                white-space: nowrap;
            }

            .cleanup-val {
                font-size: 0.9375rem;
                line-height: 1.4;
            }

            .cleanup-val a {
                color: var(--text);
                text-decoration: underline;
                text-decoration-thickness: 1px;
                text-underline-offset: 3px;
                text-decoration-color: rgba(245, 244, 238, 0.25);
            }
            .cleanup-val a:hover {
                text-decoration-color: var(--text);
            }
            .cleanup-val a:focus-visible {
                outline: 2px solid var(--accent);
                outline-offset: 2px;
                border-radius: 0;
            }

            .cleanup-reassurance {
                font-size: 0.9375rem;
                color: var(--muted);
            }

            /* ── Hero body (below h1, above CTA) ───────────── */

            .hero-body {
                width: var(--site-w);
                margin-left: var(--site-ml);
                /*padding-left: var(--edge);*/
                padding-right: var(--edge);
                display: flex;
                flex-direction: column;
                gap: 0.625rem;
                margin-bottom: clamp(2rem, 6vw, 3rem);
            }

            .hero-body p {
                line-height: 1.4;
                color: var(--text);
                font-weight: 400;
                letter-spacing: -0.03em;
                max-width: 70ch;
            }

            .hero-body p:first-child {
                font-size: clamp(3rem, 3.5vw, 2.75rem);
                line-height: 1.25;
                margin-bottom: 1rem;
            }

            .hero-body p:last-child {
                font-size: clamp(1.5rem, 2.25vw, 1.75rem);
                font-weight: 200;
                letter-spacing: -0.03em;
            }

            /* ── CTA buttons (full site width, stacked) ─────── */

            .cta-actions {
                width: var(--site-w);
                margin-left: var(--site-ml);
                display: flex;
                flex-direction: column;
                gap: 0.75rem;
                margin-bottom: clamp(2rem, 7vw, 3rem);
            }

            .cta-primary {
                display: block;
                text-align: center;
                text-transform: uppercase;
                padding: 1.1rem 1.5rem;
                font-family: "Hanken Grotesk", system-ui, sans-serif;
                font-size: clamp(1.75rem, 2vw, 1.25rem);
                font-weight: 400;
                letter-spacing: -0.04em;
                color: var(--bg);
                background: var(--btn-light);
                text-decoration: none;
                border-radius: var(--hover-radius);
                transition:
                    background-color 225ms ease,
                    color 225ms ease;
            }
            .cta-primary:hover,
            .cta-primary:focus-visible {
                background: var(--accent);
                color: var(--bg);
                outline: none;
            }

            .cta-secondary {
                display: block;
                text-align: center;
                text-transform: uppercase;
                padding: 1.1rem 1.5rem;
                font-family: "Hanken Grotesk", system-ui, sans-serif;
                font-size: clamp(1.75rem, 2vw, 1.25rem);
                letter-spacing: -0.04em;
                font-weight: 400;
                color: var(--text);
                background: var(--muted);
                text-decoration: none;
                border-radius: var(--hover-radius);
                transition:
                    background-color 225ms ease,
                    color 225ms ease;
            }
            .cta-secondary:hover,
            .cta-secondary:focus-visible {
                background: var(--accent);
                color: var(--bg);
                outline: none;
            }

            /* ── Why volunteer (Config 3-col grid) ──────────── */

            .why {
                width: var(--site-w);
                margin-left: var(--site-ml);
                margin-bottom: clamp(2rem, 7vw, 3rem);
            }

            .why__label {
                font-size: 1.2rem;
                font-weight: 600;
                letter-spacing: 0.15em;
                text-transform: uppercase;
                color: var(--text);
                margin-bottom: 0.75rem;
                display: flex;
                align-items: center;
                gap: 0.625rem;
            }

            .why__label::before {
                content: "";
                display: block;
                flex-shrink: 0;
                width: 1.25rem;
                height: 0.75rem;
                background: var(--text);
            }

            .why__grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                border-top: 1.5px solid var(--line);
                border-bottom: 1.5px solid var(--line);
            }

            .why__col {
                padding-block: 2rem;
            }

            /* Right padding on every col except last — gap before the divider */
            .why__col:not(:last-child) {
                padding-right: clamp(0rem, 2.5vw, 1.5rem);
            }

            /* Left padding + divider on col 2 and col 3 */
            .why__col + .why__col {
                border-left: 1.5px solid var(--line);
                padding-left: clamp(1rem, 2.5vw, 1.5rem);
            }

            .why__col h3 {
                font-family: "Fraunces", Georgia, serif;
                font-size: clamp(2rem, 3vw, 2rem);
                font-weight: 350;
                letter-spacing: -0.03em;
                font-optical-sizing: auto;
                font-variation-settings:
                    "SOFT" 50,
                    "WONK" 1;
                line-height: 1.1;
                margin-bottom: 0.75rem;
            }

            .why__col p {
                font-size: 1.2rem;
                line-height: 1.6;
                font-weight: 300;
                color: var(--text);
            }

            @media (max-width: 760px) {
                .why__grid {
                    grid-template-columns: 1fr;
                }
                .why__col + .why__col {
                    border-left: none;
                    border-top: 1.5px solid var(--line);
                    padding-left: 0;
                }
                .why__col:not(:last-child) {
                    padding-right: 0;
                }
            }

            /* ── Subscribe (iframe) ─────────────────────────── */

            .subscribe {
                text-align: center;
                margin-bottom: clamp(2rem, 7vw, 3rem);
            }

            .subscribe-copy {
                font-size: 1rem;
                line-height: 1.55;
                max-width: 36ch;
                margin-inline: auto;
                margin-bottom: 0.875rem;
            }

            .iframe-wrap {
                width: min(480px, 100%);
                margin-inline: auto;
                border-radius: 0;
                overflow: hidden;
                box-shadow: 0 2px 20px rgba(0, 0, 0, 0.35);
            }

            .iframe-wrap iframe {
                display: block;
                width: 100%;
            }

            /* ── /join page ─────────────────────────────────── */

            /* ── /join page ─────────────────────────────────── */

            .join-page {
                position: relative;
                width: var(--site-w);
                margin-left: var(--site-ml);
                padding-top: clamp(3rem, 8vw, 5rem);
                padding-bottom: clamp(2rem, 7vw, 3rem);
            }

            .join-cart-cell {
                display: flex;
                justify-content: flex-end;
                align-items: flex-start;
            }

            .join-cart {
                display: block;
                width: clamp(100px, 18vw, 240px);
                height: auto;
                pointer-events: none;
                user-select: none;
            }

            .join-map {
                display: block;
                width: 100%;
                aspect-ratio: 1.618;
                border: 0;
                filter: invert(100%) hue-rotate(180deg);
            }

            .join-page h1 {
                margin-bottom: 1.25rem;
            }

            .join-countdown {
                font-size: clamp(1.5rem, 3vw, 2.25rem);
                font-weight: 300;
                letter-spacing: -0.02em;
                line-height: 1.2;
                margin-bottom: 1.25rem;
            }

            .join-sub {
                font-size: 1.0625rem;
                line-height: 1.55;
                color: var(--text);
                margin-bottom: clamp(2rem, 5vw, 3rem);
            }

            .join-details {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: clamp(1.5rem, 3vw, 2.5rem);
                margin-bottom: clamp(2rem, 5vw, 3rem);
            }

            @media (max-width: 540px) {
                .join-where     { grid-column: 1 / -1; }
                .join-map-cell  { grid-column: 1 / -1; }
                .join-questions { grid-column: 1 / -1; }
            }

            .join-detail-label {
                font-size: 1.5rem;
                font-weight: 400;
                letter-spacing: 0em;
                text-transform: uppercase;
                color: var(--text);
                margin-bottom: 0.5rem;
            }

            .join-detail-value {
                font-size: clamp(1.1rem, 2vw, 1.4rem);
                font-weight: 300;
                line-height: 1.45;
            }

            .join-reassurance {
                font-size: 1rem;
                font-weight: 400;
                color: var(--text);
                opacity: 0.6;
            }

            .back-link {
                font-size: 0.9375rem;
                color: var(--muted);
                text-decoration: underline;
                text-decoration-thickness: 1px;
                text-underline-offset: 3px;
                text-decoration-color: rgba(245, 244, 238, 0.25);
            }
            .back-link:hover {
                text-decoration-color: var(--text);
                color: var(--text);
            }
            .back-link:focus-visible {
                outline: 2px solid var(--accent);
                outline-offset: 2px;
                border-radius: 0;
            }

            /* ── Stub pages ─────────────────────────────────── */

            .stub-page {
                padding: clamp(3rem, 8vw, 5rem) var(--edge)
                    clamp(2rem, 7vw, 3rem);
            }

            .stub-page h1 {
                margin-bottom: 1rem;
            }

            .stub-desc {
                color: var(--muted);
                margin-bottom: 2rem;
                font-size: 1.0625rem;
                line-height: 1.55;
            }

            /* ── Footer ─────────────────────────────────────── */

            .site-footer {
                border-top: 1.5px solid var(--line);
                margin-top: auto;
                padding-top: clamp(2rem, 5vw, 3rem);
            }

            .footer-grid {
                width: var(--site-w);
                margin-left: var(--site-ml);
                padding-bottom: var(--edge);
                display: grid;
                grid-template-columns: auto auto 1fr;
                gap: clamp(1.5rem, 5vw, 3rem);
                align-items: end;
            }

            .footer-col {
                display: flex;
                flex-direction: column;
                gap: 0;
                align-items: flex-start;
            }

            .footer-col a {
                font-size: 1rem;
                font-weight: 400;
                letter-spacing: 0.03em;
                text-transform: uppercase;
                color: var(--text);
                text-decoration: none;
                box-shadow: none;
                border-radius: var(--hover-radius);
                padding: 0.5625rem 0.5rem;
                transition:
                    background-color 225ms ease,
                    color 225ms ease;
            }
            .footer-col a:hover,
            .footer-col a:focus-visible {
                background: var(--accent);
                color: var(--bg);
                box-shadow: none;
                outline: none;
            }

            .footer-right {
                font-size: 1rem;
                font-weight: 400;
                letter-spacing: 0em;
                text-align: right;
                display: flex;
                flex-direction: column;
                align-items: flex-end;
                gap: 0.625rem;
            }

            .footer-copyright {
                /*font-size: 0.6875rem;
                font-weight: 600;
                letter-spacing: 0.12em;
                color: var(--text);*/
                /*opacity: 0.3;*/
            }

            @media (max-width: 600px) {
                .footer-grid {
                    grid-template-columns: 1fr;
                    gap: 1.5rem;
                }
                .footer-right {
                    text-align: left;
                    align-items: flex-start;
                }
            }

            /* ── Mobile nav ─────────────────────────────────── */

            .nav-menu-btn {
                /* Sits in its own fixed layer above the mobile menu so it's always reachable */
                display: none;
                position: fixed;
                top: 0;
                right: calc((100vw - var(--site-w)) / 2);
                height: var(--nav-h);
                z-index: 400;
                align-items: center;
                justify-content: center;
                background: none;
                border: none;
                color: var(--text);
                cursor: pointer;
                padding: 0.5rem;
                line-height: 0;
                transition: color 225ms ease;
            }
            .nav-menu-btn:focus-visible { color: var(--accent); outline: none; }
            @media (hover: hover) {
                .nav-menu-btn:hover { color: var(--accent); outline: none; }
            }
            .nav-menu-btn svg { width: 1.75rem; height: 1.75rem; overflow: visible; }

            /* Morphing hamburger ↔ ✕ */
            .menu-icon__bar {
                transform-box: view-box;
                transform-origin: center;
                transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            }
            .menu-icon__bar--top { transform: translateY(-12.5%) rotate(0deg); }
            .menu-icon__bar--btm { transform: translateY( 12.5%) rotate(0deg); }
            .nav-menu-btn[aria-expanded="true"] .menu-icon__bar--top { transform: translateY(0%) rotate( 45deg); }
            .nav-menu-btn[aria-expanded="true"] .menu-icon__bar--btm { transform: translateY(0%) rotate(-45deg); }


            .mobile-menu {
                display: flex;
                position: fixed;
                inset: 0;
                z-index: 300;
                background: var(--bg);
                flex-direction: column;
                visibility: hidden;
            }
            .mobile-menu.is-open { visibility: visible; }

            /* Touch devices only: slide in/out from the right */
            @media (hover: none) and (pointer: coarse) {
                .mobile-menu {
                    translate: 100%;
                    transition:
                        translate 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                        visibility 0s 0.4s;
                }
                .mobile-menu.is-open {
                    translate: 0%;
                    transition:
                        translate 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                        visibility 0s 0s;
                }
            }


            .mobile-menu-links {
                flex: 1;
                display: flex;
                flex-direction: column;
                justify-content: flex-start;
                align-items: center;
                gap: 0.25rem;
                padding-top: clamp(4rem, 12vh, 6rem);
            }

            .mobile-menu-link {
                font-size: clamp(2.5rem, 10vw, 3.5rem);
                font-weight: 300;
                letter-spacing: 0.04em;
                text-transform: uppercase;
                color: var(--text);
                text-decoration: none;
                line-height: 1.25;
                padding: 0.25rem 1rem;
                border-radius: var(--hover-radius);
                transition:
                    background-color 225ms ease,
                    color 225ms ease;
            }
            .mobile-menu-link:hover,
            .mobile-menu-link:focus-visible {
                background: var(--accent);
                color: var(--bg);
                outline: none;
            }

            .mobile-menu-ctas {
                display: flex;
                flex-direction: column;
                gap: 0.75rem;
                padding: clamp(1.25rem, 4vw, 2rem);
            }
            .mobile-menu-ctas .cta-primary {
                background: var(--accent);
                color: var(--bg);
                font-size: 1.5rem;
                transition:
                    background-color 225ms ease,
                    color 225ms ease;
            }
            .mobile-menu-ctas .cta-primary:hover,
            .mobile-menu-ctas .cta-primary:focus-visible {
                background: var(--btn-light);
                color: var(--bg);
                outline: none;
            }
            .mobile-menu-ctas .cta-secondary {
                background: var(--muted);
                color: var(--text);
                font-size: 1.5rem;
                transition:
                    background-color 225ms ease,
                    color 225ms ease;
            }
            .mobile-menu-ctas .cta-secondary:hover,
            .mobile-menu-ctas .cta-secondary:focus-visible {
                background: var(--accent);
                color: var(--bg);
                outline: none;
            }

            @media (max-width: 1024px) {
                .nav-wordmark { display: none; }
                .nav-links    { display: none; }
                .nav-menu-btn { display: flex; }

                /* Ticker expands to fill; nav is a fixed-width spacer for the external button. */
                .site-chrome.compact .ticker-bar { flex: 1; min-width: 0; }
                .site-chrome.compact .nav        { flex: 0 0 2.75rem; } /* 1.75rem svg + 2×0.5rem padding */
            }

            /* Touch devices: instant tap response + persistent highlight.
               hover:none = no hover capability (finger); pointer:coarse = imprecise input.
               Kills transitions so bg-color is immediate, then :focus keeps the accent
               on the tapped element until navigation replaces the page. */
            @media (hover: none) and (pointer: coarse) {
                a, button {
                    transition: none !important;
                }
                .footer-col a:focus,
                .nav-link:focus,
                .nav-btn:focus,
                .cta-primary:focus,
                .cta-secondary:focus,
                .mobile-menu-link:focus {
                    background-color: var(--accent);
                    color: var(--bg);
                    box-shadow: none;
                    outline: none;
                }
                a:not([class]):focus {
                    background-color: var(--accent);
                    color: var(--bg);
                    box-shadow: inset 0 -1.25px 0 0 var(--accent);
                    outline: none;
                }
            }
        </style>
    </head>

