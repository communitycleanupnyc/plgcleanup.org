---
interface Props {
    title?: string;
    description?: string;
}
const {
    title = "Community Cleanup PLG",
    description = "We clean Prospect Lefferts Gardens. No registration, all supplies included. Just show up.",
} = Astro.props;

const TICKER_TEXT =
    "2,972.55 pounds of trash collected since January 1, 2026 by 300+ volunteers";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="theme-color" content="#14130F" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
        <link rel="apple-touch-icon" href="/images/logo.webp" />
        <link
            rel="preload"
            href="/fonts/HankenGrotesk.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link
            rel="preload"
            href="/fonts/Fraunces.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />

        <style is:global>
            @font-face {
                font-family: "Fraunces";
                src: url("/fonts/Fraunces.woff2") format("woff2-variations");
                font-weight: 100 900;
                font-display: swap;
            }
            @font-face {
                font-family: "Hanken Grotesk";
                src: url("/fonts/HankenGrotesk.woff2")
                    format("woff2-variations");
                font-weight: 100 900;
                font-display: swap;
            }

            :root {
                --bg: #14130f;
                --text: #f5f4ee;
                --muted: #9a988f;
                --line: rgba(255, 255, 255, 0.14);
                --brand: #63c9ea;
                --accent: #a1d74a;
                --select: #eeb408;
                --edge: clamp(1.25rem, 5vw, 3rem);
                --ticker-h: 2.25rem;
                --nav-h: 3.5rem;
            }

            *,
            *::before,
            *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            html {
                background: var(--bg);
            }

            ::selection {
                background: var(--select);
                color: var(--bg);
            }
            ::-moz-selection {
                background: var(--select);
                color: var(--bg);
            }

            body {
                font-family: "Hanken Grotesk", system-ui, sans-serif;
                font-variant-numeric: slashed-zero;
                background: var(--bg);
                color: var(--text);
                min-height: 100svh;
                display: flex;
                flex-direction: column;
                overflow-x: clip;
            }

            .sr-only {
                position: absolute;
                width: 1px;
                height: 1px;
                padding: 0;
                margin: -1px;
                overflow: hidden;
                clip: rect(0, 0, 0, 0);
                white-space: nowrap;
                border: 0;
            }

            /* ── Ticker ─────────────────────────────────────── */

            .ticker {
                position: sticky;
                top: 0;
                z-index: 50;
                display: flex;
                align-items: center;
                height: var(--ticker-h);
                background: var(--bg);
                border-bottom: 1px solid var(--line);
                overflow: hidden;
            }

            .ticker__btn {
                flex-shrink: 0;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                width: calc(var(--ticker-h) + 0.5rem);
                height: var(--ticker-h);
                border: none;
                background: transparent;
                color: var(--muted);
                cursor: pointer;
                border-right: 1px solid var(--line);
                transition: color 0.15s;
            }
            .ticker__btn:hover {
                color: var(--text);
            }
            .ticker__btn:focus-visible {
                outline: 2px solid var(--accent);
                outline-offset: -2px;
            }

            .ticker__btn .icon-pause {
                display: none;
            }
            .ticker.is-playing .ticker__btn .icon-play {
                display: none;
            }
            .ticker.is-playing .ticker__btn .icon-pause {
                display: block;
            }

            .ticker__mask {
                flex: 1;
                overflow: hidden;
                height: 100%;
                display: flex;
                align-items: center;
            }

            .ticker__track {
                display: inline-flex;
                gap: 3rem;
                white-space: nowrap;
                font-size: 0.6875rem;
                font-weight: 500;
                letter-spacing: 0.04em;
                color: var(--muted);
                font-variant-numeric: tabular-nums slashed-zero;
                animation: ticker-scroll 32s linear infinite;
                animation-play-state: paused;
                padding-left: 1rem;
            }

            .ticker.is-playing .ticker__track {
                animation-play-state: running;
            }

            @keyframes ticker-scroll {
                to {
                    transform: translateX(-50%);
                }
            }

            @media (prefers-reduced-motion: reduce) {
                .ticker__track {
                    animation: none;
                }
            }

            /* ── Nav ────────────────────────────────────────── */

            .nav {
                position: fixed;
                top: var(--ticker-h);
                left: 0;
                right: 0;
                z-index: 40;
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 0 var(--edge);
                height: var(--nav-h);
                transition:
                    transform 0.25s ease,
                    background 0.25s ease,
                    backdrop-filter 0.25s ease;
            }

            .nav--hidden {
                transform: translateY(-130%);
            }

            .nav--solid {
                background: rgba(20, 19, 15, 0.92);
                backdrop-filter: blur(12px);
                -webkit-backdrop-filter: blur(12px);
            }

            .nav-home {
                display: inline-flex;
                align-items: center;
                text-decoration: none;
                border-radius: 4px;
            }
            .nav-home:focus-visible {
                outline: 2px solid var(--accent);
                outline-offset: 4px;
            }

            .logo-mark {
                width: 32px;
                height: 32px;
                flex-shrink: 0;
                background: var(--brand);
                -webkit-mask: url(/images/logo.webp) center / contain no-repeat;
                mask: url(/images/logo.webp) center / contain no-repeat;
            }

            .nav-links {
                display: flex;
                align-items: center;
                gap: 1.5rem;
            }

            .nav-link {
                font-size: 0.75rem;
                font-weight: 600;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                color: var(--muted);
                text-decoration: none;
                transition: color 0.15s;
            }
            .nav-link:hover {
                color: var(--text);
            }
            .nav-link:focus-visible {
                outline: 2px solid var(--accent);
                outline-offset: 3px;
                border-radius: 2px;
            }

            .nav-btn {
                display: inline-flex;
                align-items: center;
                font-size: 0.75rem;
                font-weight: 700;
                letter-spacing: 0.06em;
                text-transform: uppercase;
                color: var(--bg);
                background: var(--accent);
                text-decoration: none;
                padding: 0.375rem 0.875rem;
                border-radius: 999px;
                transition: opacity 0.15s;
            }
            .nav-btn:hover {
                opacity: 0.85;
            }
            .nav-btn:focus-visible {
                outline: 3px solid var(--text);
                outline-offset: 3px;
            }

            /* ── Main ───────────────────────────────────────── */

            main {
                flex: 1;
                max-width: 900px;
                width: 100%;
                margin-inline: auto;
                padding-top: var(--nav-h);
            }

            /* ── Hero (home page) ───────────────────────────── */

            .hero {
                position: relative;
                padding-left: var(--edge);
                padding-top: clamp(3rem, 8vw, 5rem);
                margin-bottom: clamp(2rem, 7vw, 3.5rem);
            }

            .hero-kicker {
                font-size: 0.6875rem;
                font-weight: 500;
                letter-spacing: 0.15em;
                text-transform: uppercase;
                color: var(--muted);
                margin-bottom: 0.875rem;
            }

            h1 {
                font-family: "Fraunces", Georgia, serif;
                font-size: clamp(3.25rem, 11vw, 6rem);
                font-weight: 800;
                line-height: 0.98;
                letter-spacing: -0.03em;
                font-optical-sizing: auto;
                font-variation-settings:
                    "SOFT" 50,
                    "WONK" 1;
                position: relative;
                z-index: 1;
            }

            .raccoon {
                position: absolute;
                z-index: 0;
                right: var(--edge);
                top: 85%;
                transform: translateY(-50%) rotate(-20deg);
                width: clamp(100px, 26vw, 148px);
                height: auto;
                pointer-events: none;
                user-select: none;
                opacity: 0.88;
            }

            @media (max-width: 380px) {
                .raccoon {
                    width: 100px;
                }
            }

            /* ── Next Cleanup grid ──────────────────────────── */

            .cleanup {
                display: grid;
                grid-template-columns: auto auto 1fr;
                column-gap: 0.5rem;
                row-gap: 0.4rem;
                width: fit-content;
                max-width: calc(100% - var(--edge) * 2);
                margin-inline: auto;
                align-items: center;
                text-align: left;
                margin-bottom: clamp(1.5rem, 5vw, 2.5rem);
            }

            .cleanup .span {
                grid-column: 2 / 4;
            }

            .cleanup .icon-cell {
                width: 18px;
                height: 18px;
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--muted);
                flex-shrink: 0;
            }
            .cleanup .icon-cell svg {
                width: 100%;
                height: 100%;
            }

            .cleanup a.icon-cell {
                text-decoration: none;
                border-radius: 2px;
                transition: color 0.15s;
            }
            .cleanup a.icon-cell:hover {
                color: var(--brand);
            }
            .cleanup a.icon-cell:focus-visible {
                outline: 2px solid var(--accent);
                outline-offset: 3px;
            }

            .cleanup-countdown {
                font-size: 0.6875rem;
                font-weight: 500;
                letter-spacing: 0.15em;
                text-transform: uppercase;
                color: var(--muted);
            }

            .cleanup-key {
                font-size: 0.9375rem;
                font-weight: 600;
                white-space: nowrap;
            }

            .cleanup-val {
                font-size: 0.9375rem;
                line-height: 1.4;
            }

            .cleanup-val a {
                color: var(--text);
                text-decoration: underline;
                text-decoration-thickness: 1px;
                text-underline-offset: 3px;
                text-decoration-color: rgba(245, 244, 238, 0.25);
            }
            .cleanup-val a:hover {
                text-decoration-color: var(--text);
            }
            .cleanup-val a:focus-visible {
                outline: 2px solid var(--accent);
                outline-offset: 2px;
                border-radius: 2px;
            }

            .cleanup-reassurance {
                font-size: 0.9375rem;
                color: var(--muted);
            }

            /* ── Join button ────────────────────────────────── */

            .join-wrap {
                display: flex;
                justify-content: center;
                margin-bottom: clamp(2rem, 7vw, 3rem);
            }

            .join-btn {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-family: "Hanken Grotesk", system-ui, sans-serif;
                font-size: clamp(1.1rem, 2.2vw, 1.5rem);
                font-weight: 600;
                color: var(--bg);
                background: var(--accent);
                text-decoration: none;
                padding: 1rem 2.25rem;
                min-height: 56px;
                border-radius: 999px;
                transition: opacity 0.15s;
            }
            .join-btn:hover {
                opacity: 0.88;
            }
            .join-btn:focus-visible {
                outline: 3px solid var(--text);
                outline-offset: 3px;
            }
            .join-btn:active {
                opacity: 0.75;
            }

            /* ── Why volunteer (Config 3-col grid) ──────────── */

            .why {
                /* break out of main's 900px to be 95vw */
                width: 95vw;
                margin-left: calc(50% - 47.5vw);
                margin-bottom: clamp(2rem, 7vw, 3rem);
            }

            .why__label {
                font-size: 0.6875rem;
                font-weight: 600;
                letter-spacing: 0.15em;
                text-transform: uppercase;
                color: var(--muted);
                margin-bottom: 0.75rem;
                padding-left: clamp(1rem, 2.5vw, 1.5rem);
            }

            .why__label::before {
                content: "▪ ";
            }

            .why__grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                border-top: 1px solid var(--line);
                border-bottom: 1px solid var(--line);
            }

            .why__col {
                padding: 2rem clamp(1rem, 2.5vw, 1.5rem);
            }

            .why__col + .why__col {
                border-left: 1px solid var(--line);
            }

            .why__col h3 {
                font-family: "Fraunces", Georgia, serif;
                font-size: clamp(1.4rem, 3vw, 2rem);
                font-weight: 600;
                font-optical-sizing: auto;
                font-variation-settings:
                    "SOFT" 50,
                    "WONK" 1;
                line-height: 1.1;
                margin-bottom: 0.75rem;
            }

            .why__col p {
                font-size: 0.9375rem;
                line-height: 1.6;
                color: var(--muted);
            }

            @media (max-width: 760px) {
                .why__grid {
                    grid-template-columns: 1fr;
                }
                .why__col + .why__col {
                    border-left: none;
                    border-top: 1px solid var(--line);
                }
            }

            /* ── Subscribe (iframe) ─────────────────────────── */

            .subscribe {
                text-align: center;
                margin-bottom: clamp(2rem, 7vw, 3rem);
            }

            .subscribe-copy {
                font-size: 1rem;
                line-height: 1.55;
                max-width: 36ch;
                margin-inline: auto;
                margin-bottom: 0.875rem;
            }

            .iframe-wrap {
                width: min(480px, 100%);
                margin-inline: auto;
                border-radius: 8px;
                overflow: hidden;
                box-shadow: 0 2px 20px rgba(0, 0, 0, 0.35);
            }

            .iframe-wrap iframe {
                display: block;
                width: 100%;
            }

            /* ── /join page ─────────────────────────────────── */

            .join-page {
                padding-inline: var(--edge);
                padding-bottom: clamp(2rem, 7vw, 3rem);
            }

            .join-page h1 {
                margin-bottom: 0.75rem;
            }

            .join-sub {
                font-size: 1.0625rem;
                line-height: 1.55;
                color: var(--muted);
                margin-bottom: clamp(1.5rem, 5vw, 2.5rem);
            }

            .join-reassurance {
                font-size: 1rem;
                font-weight: 600;
                margin-top: 0.75rem;
                margin-bottom: clamp(2rem, 7vw, 3rem);
            }

            .back-link {
                font-size: 0.9375rem;
                color: var(--muted);
                text-decoration: underline;
                text-decoration-thickness: 1px;
                text-underline-offset: 3px;
                text-decoration-color: rgba(245, 244, 238, 0.25);
            }
            .back-link:hover {
                text-decoration-color: var(--text);
                color: var(--text);
            }
            .back-link:focus-visible {
                outline: 2px solid var(--accent);
                outline-offset: 2px;
                border-radius: 2px;
            }

            /* ── Stub pages ─────────────────────────────────── */

            .stub-page {
                padding: clamp(3rem, 8vw, 5rem) var(--edge) clamp(2rem, 7vw, 3rem);
            }

            .stub-page h1 {
                margin-bottom: 1rem;
            }

            .stub-desc {
                color: var(--muted);
                margin-bottom: 2rem;
                font-size: 1.0625rem;
                line-height: 1.55;
            }

            /* ── Footer ─────────────────────────────────────── */

            .site-footer {
                border-top: 1px solid var(--line);
                margin-top: auto;
                padding-top: clamp(2rem, 5vw, 3rem);
            }

            .footer-grid {
                max-width: 900px;
                margin-inline: auto;
                padding: 0 var(--edge) var(--edge);
                display: grid;
                grid-template-columns: auto auto 1fr;
                gap: clamp(1.5rem, 5vw, 3rem);
                align-items: start;
            }

            .footer-col {
                display: flex;
                flex-direction: column;
                gap: 0.625rem;
            }

            .footer-col a {
                font-size: 0.6875rem;
                font-weight: 600;
                letter-spacing: 0.12em;
                text-transform: uppercase;
                color: var(--muted);
                text-decoration: none;
                transition: color 0.15s;
            }
            .footer-col a:hover {
                color: var(--text);
            }
            .footer-col a:focus-visible {
                outline: 2px solid var(--accent);
                outline-offset: 3px;
                border-radius: 2px;
            }

            .footer-right {
                text-align: right;
                display: flex;
                flex-direction: column;
                align-items: flex-end;
                gap: 0.625rem;
            }

            .footer-right a {
                font-size: 0.6875rem;
                font-weight: 600;
                letter-spacing: 0.12em;
                text-transform: uppercase;
                color: var(--muted);
                text-decoration: none;
                transition: color 0.15s;
            }
            .footer-right a:hover {
                color: var(--text);
            }
            .footer-right a:focus-visible {
                outline: 2px solid var(--accent);
                outline-offset: 3px;
                border-radius: 2px;
            }

            .footer-copyright {
                font-size: 0.6875rem;
                font-weight: 600;
                letter-spacing: 0.12em;
                text-transform: uppercase;
                color: var(--text);
                opacity: 0.3;
            }

            @media (max-width: 600px) {
                .footer-grid {
                    grid-template-columns: 1fr;
                    gap: 1.5rem;
                }
                .footer-right {
                    text-align: left;
                    align-items: flex-start;
                }
            }
        </style>
    </head>

    <body>
        <!-- Sticky ticker at top of viewport -->
        <div class="ticker" id="ticker">
            <button
                class="ticker__btn"
                id="ticker-btn"
                aria-pressed="false"
                aria-label="Play ticker"
            >
                <!-- play -->
                <svg
                    class="icon-play"
                    aria-hidden="true"
                    viewBox="0 0 12 12"
                    fill="currentColor"
                    width="10"
                    height="10"
                >
                    <path d="M2 1.5l8 4.5-8 4.5V1.5z"></path>
                </svg>
                <!-- pause -->
                <svg
                    class="icon-pause"
                    aria-hidden="true"
                    viewBox="0 0 12 12"
                    fill="currentColor"
                    width="10"
                    height="10"
                >
                    <rect x="2" y="1.5" width="3" height="9" rx="0.5"></rect>
                    <rect x="7" y="1.5" width="3" height="9" rx="0.5"></rect>
                </svg>
            </button>
            <div class="ticker__mask">
                <div class="ticker__track" id="ticker-track">
                    {/* 10 repetitions → animation moves -50% = 5 spans seamlessly */}
                    {
                        Array.from({ length: 10 }, (_, i) => (
                            <span aria-hidden={i > 0 ? "true" : undefined}>
                                {TICKER_TEXT}
                            </span>
                        ))
                    }
                </div>
            </div>
        </div>

        <!-- Fixed scroll-aware nav: logo left | ABOUT · FAQ · JOIN US right -->
        <nav class="nav" id="main-nav" aria-label="Site navigation">
            <a
                href="/"
                class="nav-home"
                aria-label="Community Cleanup PLG — home"
            >
                <div class="logo-mark" aria-hidden="true"></div>
            </a>
            <div class="nav-links">
                <a href="/about" class="nav-link">About</a>
                <a href="/faq" class="nav-link">FAQ</a>
                <a href="/join" class="nav-btn">Join us</a>
            </div>
        </nav>

        <main>
            <slot />
        </main>

        <footer class="site-footer">
            <div class="footer-grid">
                <div class="footer-col">
                    <a href="/join">Join us</a>
                    <a href="/faq">FAQ</a>
                    <a href="/about">About</a>
                </div>
                <div class="footer-col">
                    <a
                        href="https://discord.com/invite/H9her7r8N2"
                        target="_blank"
                        rel="noopener noreferrer">Discord</a
                    >
                    <a href="mailto:communitycleanupplg@gmail.com">Email us</a>
                    <a
                        href="https://communitycleanupplg.substack.com/subscribe"
                        target="_blank"
                        rel="noopener noreferrer">Substack</a
                    >
                    <a
                        href="https://www.instagram.com/communitycleanupplg/"
                        target="_blank"
                        rel="noopener noreferrer">Instagram</a
                    >
                    <a
                        href="https://www.amazon.com/registries/gl/guest-view/1Y3YRXM9ILG5I"
                        target="_blank"
                        rel="noopener noreferrer">Support us</a
                    >
                </div>
                <div class="footer-right">
                    <a href="/terms">Volunteering Terms</a>
                    <p class="footer-copyright">
                        &copy; Community Cleanup PLG 2026
                    </p>
                </div>
            </div>
        </footer>

        <script>
            // Ticker play/pause toggle
            const ticker = document.getElementById("ticker")!;
            const tickerBtn = document.getElementById("ticker-btn")!;
            tickerBtn.addEventListener("click", () => {
                const playing = ticker.classList.toggle("is-playing");
                tickerBtn.setAttribute("aria-pressed", String(playing));
                tickerBtn.setAttribute(
                    "aria-label",
                    playing ? "Pause ticker" : "Play ticker",
                );
            });

            // Scroll-aware nav: hide on down, reappear on up
            const nav = document.getElementById("main-nav")!;
            let lastY = 0;
            let ticking = false;
            window.addEventListener(
                "scroll",
                () => {
                    if (!ticking) {
                        requestAnimationFrame(() => {
                            const y = window.scrollY;
                            if (y < 80) {
                                nav.classList.remove(
                                    "nav--hidden",
                                    "nav--solid",
                                );
                            } else if (y > lastY) {
                                nav.classList.add("nav--hidden");
                            } else {
                                nav.classList.remove("nav--hidden");
                                nav.classList.add("nav--solid");
                            }
                            lastY = y;
                            ticking = false;
                        });
                        ticking = true;
                    }
                },
                { passive: true },
            );
        </script>
    </body>
</html>
