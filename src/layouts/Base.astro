---
import { etDateParts } from "../data/event";

interface Props {
    title?: string;
    description?: string;
}
const {
    title = "Community Cleanup PLG",
    description = "We clean Prospect Lefferts Gardens. No registration, all supplies included. Just show up.",
} = Astro.props;

const { y, m } = etDateParts(new Date());
const SEASONS = [
    "Winter",
    "Winter",
    "Spring",
    "Spring",
    "Spring",
    "Summer",
    "Summer",
    "Summer",
    "Autumn",
    "Autumn",
    "Autumn",
    "Winter",
];
const seasonLabel = `${SEASONS[m - 1]} ${y}`;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="theme-color" content="#14130F" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
        <link rel="apple-touch-icon" href="/images/logo.webp" />
        <link
            rel="preload"
            href="/fonts/HankenGrotesk.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link
            rel="preload"
            href="/fonts/Fraunces.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />

        <style is:global>
            @font-face {
                font-family: "Fraunces";
                src: url("/fonts/Fraunces.woff2") format("woff2-variations");
                font-weight: 100 900;
                font-display: swap;
            }
            @font-face {
                font-family: "Hanken Grotesk";
                src: url("/fonts/HankenGrotesk.woff2")
                    format("woff2-variations");
                font-weight: 100 900;
                font-display: swap;
            }

            :root {
                --bg: #14130f;
                --text: #f5f4ee;
                --muted: #9a988f;
                --line: rgba(255, 255, 255, 0.14);
                --brand: #63c9ea;
                --accent: #a1d74a;
                --select: #eeb408;
                --edge: clamp(1.25rem, 5vw, 3rem);
            }

            *,
            *::before,
            *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            html {
                background: var(--bg);
            }

            ::selection {
                background: var(--select);
                color: var(--bg);
            }
            ::-moz-selection {
                background: var(--select);
                color: var(--bg);
            }

            body {
                font-family: "Hanken Grotesk", system-ui, sans-serif;
                font-variant-numeric: slashed-zero;
                background: var(--bg);
                color: var(--text);
                min-height: 100svh;
                display: flex;
                flex-direction: column;
                max-width: 900px;
                margin-inline: auto;
            }

            .sr-only {
                position: absolute;
                width: 1px;
                height: 1px;
                padding: 0;
                margin: -1px;
                overflow: hidden;
                clip: rect(0, 0, 0, 0);
                white-space: nowrap;
                border: 0;
            }

            /* ── Header ─────────────────────────────────────── */

            .site-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: var(--edge) var(--edge) 0;
                margin-bottom: 20vh;
            }

            .logo-mark {
                width: 44px;
                height: 44px;
                flex-shrink: 0;
                background: var(--brand);
                -webkit-mask: url(/images/logo.webp) center / contain no-repeat;
                mask: url(/images/logo.webp) center / contain no-repeat;
            }

            .season-label {
                font-size: 0.6875rem;
                font-weight: 500;
                letter-spacing: 0.15em;
                text-transform: uppercase;
                color: var(--muted);
            }

            /* ── Main ───────────────────────────────────────── */

            main {
                flex: 1;
            }

            /* ── Hero (home page) ───────────────────────────── */

            .hero {
                position: relative;
                padding-left: var(--edge);
                margin-bottom: clamp(2rem, 7vw, 3.5rem);
            }

            h1 {
                font-family: "Fraunces", Georgia, serif;
                font-size: clamp(3.25rem, 11vw, 6rem);
                font-weight: 800;
                line-height: 0.98;
                letter-spacing: -0.03em;
                font-optical-sizing: auto;
                font-variation-settings:
                    "SOFT" 50,
                    "WONK" 1;
                position: relative;
                z-index: 1;
            }

            .raccoon {
                position: absolute;
                z-index: 0;
                right: var(--edge);
                top: 85%;
                transform: translateY(-50%) rotate(-20deg);
                width: clamp(100px, 26vw, 148px);
                height: auto;
                pointer-events: none;
                user-select: none;
                opacity: 0.88;
            }

            @media (max-width: 380px) {
                .raccoon {
                    width: 100px;
                }
            }

            /* ── Next Cleanup grid ──────────────────────────── */

            .cleanup {
                display: grid;
                grid-template-columns: auto auto 1fr;
                column-gap: 0.5rem;
                row-gap: 0.4rem;
                width: fit-content;
                max-width: calc(100% - var(--edge) * 2);
                margin-inline: auto;
                align-items: center;
                text-align: left;
                margin-bottom: clamp(1.5rem, 5vw, 2.5rem);
            }

            .cleanup .span {
                grid-column: 2 / 4;
            }

            .cleanup .icon-cell {
                width: 18px;
                height: 18px;
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--muted);
                flex-shrink: 0;
            }
            .cleanup .icon-cell svg {
                width: 100%;
                height: 100%;
            }

            .cleanup a.icon-cell {
                text-decoration: none;
                border-radius: 2px;
                transition: color 0.15s;
            }
            .cleanup a.icon-cell:hover {
                color: var(--brand);
            }
            .cleanup a.icon-cell:focus-visible {
                outline: 2px solid var(--accent);
                outline-offset: 3px;
            }

            .cleanup-countdown {
                font-size: 0.6875rem;
                font-weight: 500;
                letter-spacing: 0.15em;
                text-transform: uppercase;
                color: var(--muted);
            }

            .cleanup-key {
                font-size: 0.9375rem;
                font-weight: 600;
                white-space: nowrap;
            }

            .cleanup-val {
                font-size: 0.9375rem;
                line-height: 1.4;
            }

            .cleanup-val a {
                color: var(--text);
                text-decoration: underline;
                text-decoration-thickness: 1px;
                text-underline-offset: 3px;
                text-decoration-color: rgba(245, 244, 238, 0.25);
            }
            .cleanup-val a:hover {
                text-decoration-color: var(--text);
            }
            .cleanup-val a:focus-visible {
                outline: 2px solid var(--accent);
                outline-offset: 2px;
                border-radius: 2px;
            }

            .cleanup-reassurance {
                font-size: 0.9375rem;
                color: var(--muted);
            }

            /* ── Join button ────────────────────────────────── */

            .join-wrap {
                display: flex;
                justify-content: center;
                margin-bottom: clamp(2rem, 7vw, 3rem);
            }

            .join-btn {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-family: "Hanken Grotesk", system-ui, sans-serif;
                font-size: clamp(1.1rem, 2.2vw, 1.5rem);
                font-weight: 600;
                color: var(--bg);
                background: var(--accent);
                text-decoration: none;
                padding: 1rem 2.25rem;
                min-height: 56px;
                border-radius: 999px;
                transition: opacity 0.15s;
            }
            .join-btn:hover {
                opacity: 0.88;
            }
            .join-btn:focus-visible {
                outline: 3px solid var(--text);
                outline-offset: 3px;
            }
            .join-btn:active {
                opacity: 0.75;
            }

            /* ── Why volunteer ──────────────────────────────── */

            .why {
                max-width: 680px;
                margin-inline: auto;
                padding-inline: var(--edge);
                margin-bottom: clamp(2rem, 7vw, 3rem);
            }

            .why-heading {
                font-family: "Fraunces", Georgia, serif;
                font-size: clamp(1.5rem, 4vw, 2rem);
                font-weight: 700;
            }

            .why-block h3 {
                font-size: 1rem;
                font-weight: 700;
                margin-bottom: 0.375rem;
            }

            .why-block p {
                font-size: 0.9375rem;
                line-height: 1.6;
                color: var(--muted);
            }

            .why > * + * {
                border-top: 1px solid var(--line);
                padding-top: 1.25rem;
                margin-top: 1.25rem;
            }

            /* ── Subscribe (iframe) ─────────────────────────── */

            .subscribe {
                text-align: center;
                margin-bottom: clamp(2rem, 7vw, 3rem);
            }

            .subscribe-copy {
                font-size: 1rem;
                line-height: 1.55;
                max-width: 36ch;
                margin-inline: auto;
                margin-bottom: 0.875rem;
            }

            .iframe-wrap {
                width: min(480px, 100%);
                margin-inline: auto;
                border-radius: 8px;
                overflow: hidden;
                box-shadow: 0 2px 20px rgba(0, 0, 0, 0.35);
            }

            .iframe-wrap iframe {
                display: block;
                width: 100%;
            }

            /* ── /join page ─────────────────────────────────── */

            .join-page {
                padding-inline: var(--edge);
                padding-bottom: clamp(2rem, 7vw, 3rem);
            }

            .join-page h1 {
                margin-bottom: 0.75rem;
            }

            .join-sub {
                font-size: 1.0625rem;
                line-height: 1.55;
                color: var(--muted);
                margin-bottom: clamp(1.5rem, 5vw, 2.5rem);
            }

            .join-reassurance {
                font-size: 1rem;
                font-weight: 600;
                margin-top: 0.75rem;
                margin-bottom: clamp(2rem, 7vw, 3rem);
            }

            .back-link {
                font-size: 0.9375rem;
                color: var(--muted);
                text-decoration: underline;
                text-decoration-thickness: 1px;
                text-underline-offset: 3px;
                text-decoration-color: rgba(245, 244, 238, 0.25);
            }
            .back-link:hover {
                text-decoration-color: var(--text);
                color: var(--text);
            }
            .back-link:focus-visible {
                outline: 2px solid var(--accent);
                outline-offset: 2px;
                border-radius: 2px;
            }

            /* ── Footer ─────────────────────────────────────── */

            footer {
                margin-top: auto;
                padding-top: clamp(2.5rem, 8vw, 4rem);
            }

            .footer-icons {
                display: flex;
                justify-content: center;
                gap: 0;
                list-style: none;
                margin-bottom: 1rem;
            }

            .footer-icons a {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                width: 44px;
                height: 44px;
                color: var(--muted);
                border-radius: 4px;
                transition: color 0.15s;
            }
            .footer-icons a:hover {
                color: var(--brand);
            }
            .footer-icons a:focus-visible {
                outline: 2px solid var(--accent);
                outline-offset: 2px;
            }

            /* Optical balance: brand (filled, edge-to-edge) at 20px; UI outline at 22px */
            .icon-brand {
                width: 20px;
                height: 20px;
            }
            .icon-ui {
                width: 22px;
                height: 22px;
            }

            .copyright {
                font-size: 0.6875rem;
                color: var(--text);
                opacity: 0.3;
                margin-left: var(--edge);
                margin-bottom: var(--edge);
            }
        </style>
    </head>

    <body>
        <header class="site-header">
            <div
                class="logo-mark"
                role="img"
                aria-label="Community Cleanup PLG"
            >
            </div>
            <span class="season-label">{seasonLabel}</span>
        </header>

        <main>
            <slot />
        </main>

        <footer>
            <ul class="footer-icons">
                <li>
                    <a
                        href="https://www.instagram.com/communitycleanupplg/"
                        aria-label="Instagram"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <svg
