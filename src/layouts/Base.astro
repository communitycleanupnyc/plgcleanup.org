        <script>
            // Declare first — used by both ticker and scroll sections
            const chrome = document.getElementById("site-chrome")!;
            const isStaticNav = chrome.classList.contains("static-nav");

            // ── Ticker ──────────────────────────────────────────
            const ticker = document.getElementById("ticker")!;
            const tickerToggle = document.getElementById("ticker-toggle")!;
            const tickerTrack = ticker.querySelector(".ticker__track") as HTMLElement;
            const tickerViewport = ticker.querySelector(".ticker__viewport") as HTMLElement;

            // Clone segments until track fills 3× the viewport, then pin --seg-w.
            // Animates from translateX(0) → translateX(--seg-w) so the loop is
            // seamless at any viewport width, with natural inter-segment spacing.
            function fillTicker() {
                const template = tickerTrack.children[0] as HTMLElement;
                const segW = template.offsetWidth;
                if (!segW) return;
                const target = tickerViewport.offsetWidth * 3;
                while (tickerTrack.scrollWidth < target) {
                    const clone = template.cloneNode(true) as HTMLElement;
                    clone.setAttribute("aria-hidden", "true");
                    clone.setAttribute("tabindex", "-1");
                    tickerTrack.appendChild(clone);
                }
                tickerTrack.style.setProperty("--seg-w", segW + "px");
            }

            document.fonts.ready.then(fillTicker);
            new ResizeObserver(fillTicker).observe(tickerViewport);

            // Autoplay on load — only if user has no motion preference and ticker is shown
            if (
                !isStaticNav &&
                !window.matchMedia("(prefers-reduced-motion: reduce)").matches
            ) {
                ticker.classList.add("is-playing");
                tickerToggle.setAttribute("aria-pressed", "true");
                tickerToggle.setAttribute("aria-label", "Pause stats ticker");
            }

            tickerToggle.addEventListener("click", () => {
                const playing = ticker.classList.toggle("is-playing");
                tickerToggle.setAttribute("aria-pressed", String(playing));
                tickerToggle.setAttribute(
                    "aria-label",
                    playing ? "Pause stats ticker" : "Play stats ticker",
                );
            });

            // ── Mobile menu ────────────────────────────────────────────────
            const menuBtn    = document.getElementById("nav-menu-btn") as HTMLButtonElement | null;
            const mobileMenu = document.getElementById("mobile-menu") as HTMLElement | null;

            function openMobileMenu() {
                mobileMenu!.classList.add("is-open");
                menuBtn!.setAttribute("aria-expanded", "true");
                menuBtn!.setAttribute("aria-label", "Close menu");
                document.body.style.overflow = "hidden";
                mobileMenu!.querySelector<HTMLElement>(".mobile-menu-link")?.focus();
            }
            function closeMobileMenu() {
                mobileMenu!.classList.remove("is-open");
                menuBtn!.setAttribute("aria-expanded", "false");
                menuBtn!.setAttribute("aria-label", "Open menu");
                document.body.style.overflow = "";
                menuBtn!.blur();
            }

            menuBtn?.addEventListener("click", () => {
                mobileMenu?.classList.contains("is-open") ? closeMobileMenu() : openMobileMenu();
            });
            document.addEventListener("keydown", (e) => {
                if (e.key === "Escape" && mobileMenu?.classList.contains("is-open")) {
                    closeMobileMenu();
                    menuBtn?.focus(); // return focus for keyboard users closing via Escape
                }
            });

            // ── Scroll behavior ─────────────────────────────────────────────
            if (isStaticNav) {
                // Static-nav pages: start visible, hide on scroll-down, reveal on scroll-up.
                let lastY = window.scrollY;
                let ticking = false;
                window.addEventListener("scroll", () => {
                    if (!ticking) {
                        requestAnimationFrame(() => {
                            const y = window.scrollY;
                            if (y > lastY && y > 8) {
                                chrome.classList.add("is-hidden");
                            } else if (y < lastY) {
                                chrome.classList.remove("is-hidden");
                            }
                            lastY = y;
                            ticking = false;
                        });
                        ticking = true;
                    }
                }, { passive: true });
            } else {
                // Ticker pages: compact in-flow at top → fixed+revealed on scroll-up past 25vh.
                const threshold = window.innerHeight * 0.25;
                let lastY = 0;
                let ticking = false;
                window.addEventListener("scroll", () => {
                    if (!ticking) {
                        requestAnimationFrame(() => {
                            const y = window.scrollY;
                            const scrollingDown = y > lastY;
                            const pastThreshold = y > threshold;

                            if (!pastThreshold) {
                                if (chrome.classList.contains("is-fixed") && !chrome.dataset.leaving) {
                                    chrome.dataset.leaving = "1";
                                    chrome.classList.remove("is-revealed");
                                    chrome.addEventListener("transitionend", () => {
                                        delete chrome.dataset.leaving;
                                        if (!chrome.classList.contains("is-revealed")) {
                                            chrome.classList.add("no-transition");
                                            chrome.classList.remove("is-fixed");
                                            chrome.classList.add("compact");
                                            void chrome.offsetHeight;
                                            chrome.classList.remove("no-transition");
                                        }
                                    }, { once: true });
                                }
                            } else if (scrollingDown) {
                                chrome.classList.remove("is-revealed");
                            } else {
                                delete chrome.dataset.leaving;
                                if (!chrome.classList.contains("is-fixed")) {
                                    chrome.classList.add("no-transition");
                                    chrome.classList.remove("compact");
                                    chrome.classList.add("is-fixed");
                                    void chrome.offsetHeight;
                                    chrome.classList.remove("no-transition");
                                }
                                chrome.classList.add("is-revealed");
                            }

                            lastY = y;
                            ticking = false;
                        });
                        ticking = true;
                    }
                }, { passive: true });
            }
        </script>
    </body>
</html>
