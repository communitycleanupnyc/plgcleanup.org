---
import "../styles/tokens.css";
import "../styles/base.css";
import "../styles/chrome.css";
import SiteHeader from "../components/SiteHeader.astro";
import MobileMenu from "../components/MobileMenu.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { getImage } from "astro:assets";
import { featured, OG_SIZE } from "../lib/og";

// Render this build's randomly-featured testimonial into a high-res square share
// image (Sharp, build-time), and resolve it to an absolute URL for the meta tags.
const ogRendered = await getImage({
  src: featured.image,
  width: OG_SIZE,
  height: OG_SIZE,
  fit: "cover",
  position: "attention",
  format: "jpeg",
  quality: 80,
});
const ogImageUrl = new URL(ogRendered.src, Astro.site).href;

interface Props {
  title?: string;
  description?: string;
  navMode?: "ticker" | "static";
}
// Brand name + browser-tab title template, defined once. Pages pass only their
// own short title (e.g. "FAQ") and the layout appends " | Community Cleanup PLG",
// so the separator and site name live in exactly one place. No title (the home
// page) → the tab just reads the site name.
const SITE_NAME = "Community Cleanup PLG";
const SITE_DESCRIPTION =
  "We clean Prospect Lefferts Gardens. No registration, all supplies included. Just show up.";
const { title, description = SITE_DESCRIPTION, navMode = "ticker" } = Astro.props;
const fullTitle = title ? `${title} | ${SITE_NAME}` : SITE_NAME;

// This page's own absolute URL, resolved against `site` (astro.config.mjs).
// build.format "file" makes Astro.url.pathname the emitted file path
// (/about.html, /index.html), but the shareable URL — and what @astrojs/sitemap
// emits — is the clean form (/about, /). Strip the extension so canonical and
// og:url match the sitemap exactly.
const cleanPath = Astro.url.pathname.replace(/index\.html$/, "").replace(/\.html$/, "");
const canonicalURL = new URL(cleanPath, Astro.site);

// Sitewide organization identity for search/AI engines. Emitted once per page as
// JSON-LD; the homepage URL + logo are absolute so they resolve off any host.
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "NGO",
  name: SITE_NAME,
  url: new URL("/", Astro.site).href,
  logo: new URL("/images/logo.webp", Astro.site).href,
  description: SITE_DESCRIPTION,
  areaServed: "Prospect Lefferts Gardens, Brooklyn, NY",
  sameAs: [
    "https://www.instagram.com/communitycleanupplg/",
    "https://communitycleanupplg.substack.com/",
    "https://discord.com/invite/H9her7r8N2",
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#14130F" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/images/logo.webp" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content={String(OG_SIZE)} />
    <meta property="og:image:height" content={String(OG_SIZE)} />
    <meta property="og:image:alt" content="A Community Cleanup PLG volunteer" />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="preload" href="/fonts/Inter.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Fraunces.woff2" as="font" type="font/woff2" crossorigin />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(orgSchema)} />
  </head>

  <body>
    <SiteHeader navMode={navMode} />
    <MobileMenu />
    <main>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
