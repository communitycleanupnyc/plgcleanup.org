---
interface Props {
    title?: string;
    description?: string;
}
const {
    title = "Community Cleanup PLG",
    description = "We clean Prospect Lefferts Gardens. No registration, all supplies included. Just show up.",
} = Astro.props;

const TICKER_TEXT = "2,972.55 pounds this year • 300+ volunteers";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="theme-color" content="#14130F" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
        <link rel="apple-touch-icon" href="/images/logo.webp" />
        <link
            rel="preload"
            href="/fonts/HankenGrotesk.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link
            rel="preload"
            href="/fonts/Fraunces.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />

        <style is:global>
            @font-face {
                font-family: "Fraunces";
                src: url("/fonts/Fraunces.woff2") format("woff2-variations");
                font-weight: 100 900;
                font-display: swap;
            }
            @font-face {
                font-family: "Hanken Grotesk";
                src: url("/fonts/HankenGrotesk.woff2")
                    format("woff2-variations");
                font-weight: 100 900;
                font-display: swap;
            }

            :root {
                --bg: #14130f;
                --text: #f5f4ee;
                --muted: #9a988f;
                --line: rgba(255, 255, 255, 0.14);
                --brand: #63c9ea;
                --accent: #a1d74a;
                --select: #eeb408;
                --edge: clamp(1.25rem, 5vw, 3rem);
                --ticker-h: 2.25rem;
                --nav-h: 3.5rem;
                /* Round 6 additions */
                --btn-light: var(--text);
                --hover-radius: 0.5rem;
                --ticker-duration: 22s;
            }

            *,
            *::before,
            *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            html {
                background: var(--bg);
            }

            ::selection {
                background: var(--select);
                color: var(--bg);
            }
            ::-moz-selection {
                background: var(--select);
                color: var(--bg);
            }

            body {
                font-family: "Hanken Grotesk", system-ui, sans-serif;
                font-variant-numeric: slashed-zero;
                background: var(--bg);
                color: var(--text);
                min-height: 100svh;
                display: flex;
                flex-direction: column;
                overflow-x: clip;
            }

            .sr-only {
                position: absolute;
                width: 1px;
                height: 1px;
                padding: 0;
                margin: -1px;
                overflow: hidden;
                clip: rect(0, 0, 0, 0);
                white-space: nowrap;
                border: 0;
            }

            /* ── Ticker ─────────────────────────────────────── */

            /* Full-bleed sticky wrapper — masks page content through side gutters */
            .ticker-bar {
                position: sticky;
                top: 0;
                z-index: 50;
                width: 100%;
                background: var(--bg);
            }

            /* Visible 95vw bar with the bottom divider */
            .ticker {
                width: 95vw;
                margin-inline: auto;
                height: var(--ticker-h);
                display: flex;
                align-items: center;
                border-bottom: 1px solid var(--line);
            }

            .ticker__viewport {
                flex: 1;
                overflow: hidden;
                position: relative;
                height: 100%;
                display: flex;
                align-items: center;
            }

            /*
             * Two identical segments; padding-right creates the pitch (~55vw).
             * resting: translateX(-50%) = –one-segment-width = start of segment 2.
             * animation: –50% → 0 (rightward); loop is seamless (seg1 == seg2).
             */
            .ticker__track {
                display: flex;
                width: max-content;
                will-change: transform;
                transform: translateX(-50%);
                font-size: 0.6875rem;
                font-weight: 500;
                letter-spacing: 0.04em;
                color: var(--muted);
                font-variant-numeric: tabular-nums slashed-zero;
                white-space: nowrap;
            }

            .ticker__segment {
                flex-shrink: 0;
                /* trailing space sets the pitch ≈ text-width + 40vw ≈ 55vw */
                padding-right: clamp(3rem, 40vw, 35rem);
            }

            .ticker.is-playing .ticker__track {
                animation: ticker-rtl var(--ticker-duration) linear infinite;
            }

            @keyframes ticker-rtl {
                /* moves right (–50% → 0); identical copies make the loop seamless */
                from { transform: translateX(-50%); }
                to   { transform: translateX(0); }
            }

            /* Control sits on the right, outside the scrolling area */
            .ticker__toggle {
                flex: none;
                display: grid;
                place-items: center;
                width: 40px;
                height: 40px;
                margin-left: 0.5rem;
                background: none;
                border: none;
                cursor: pointer;
                color: var(--muted);
                transition: color 120ms ease;
            }
            .ticker__toggle:hover,
            .ticker__toggle:focus-visible {
                color: var(--text);
            }
            .ticker__toggle:focus-visible {
                outline: 2px solid var(--brand);
                outline-offset: 2px;
                border-radius: 999px;
            }

            /* Icon swap: show play-circle when paused, pause-circle when playing */
            .ticker__icon--pause { display: none; }
            .ticker.is-playing .ticker__icon--play  { display: none; }
            .ticker.is-playing .ticker__icon--pause { display: block; }

            /* ── Nav ────────────────────────────────────────── */

            .nav {
                position: fixed;
                top: var(--ticker-h);
                left: 0;
                right: 0;
                z-index: 40;
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 0 var(--edge);
                height: var(--nav-h);
                transition:
                    transform 0.25s ease,
                    background 0.25s ease,
                    backdrop-filter 0.25s ease;
            }

            .nav--hidden {
                transform: translateY(-130%);
            }

            .nav--solid {
                background: rgba(20, 19, 15, 0.92);
                backdrop-filter: blur(12px);
                -webkit-backdrop-filter: blur(12px);
            }

            .nav-home {
                display: inline-flex;
                align-items: center;
                text-decoration: none;
                border-radius: 4px;
            }
            .nav-home:focus-visible {
                outline: 2px solid var(--accent);
                outline-offset: 4px;
            }

            .logo-mark {
                width: 32px;
                height: 32px;
                flex-shrink: 0;
                background: var(--brand);
                -webkit-mask: url(/images/logo.webp) center / contain no-repeat;
                mask: url(/images/logo.webp) center / contain no-repeat;
            }

            .nav-links {
                display: flex;
                align-items: center;
                gap: 1.5rem;
            }

            /* Padding reserved at rest → no reflow on hover */
            .nav-link {
                font-size: 0.75rem;
                font-weight: 600;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                color: var(--muted);
                text-decoration: none;
                border-radius: var(--hover-radius);
                padding: 0.25rem 0.5rem;
                transition: background-color 120ms ease, color 120ms ease;
            }
            .nav-link:hover,
            .nav-link:focus-visible {
                background: var(--accent);
                color: var(--bg);
                outline: none;
            }

            /* JOIN US pill — keep accent bg; dim on hover, don't go green-on-green */
            .nav-btn {
                display: inline-flex;
                align-items: center;
                font-size: 0.75rem;
                font-weight: 700;
                letter-spacing: 0.06em;
                text-transform: uppercase;
                color: var(--bg);
                background: var(--accent);
                text-decoration: none;
                padding: 0.375rem 0.875rem;
                border-radius: 999px;
                transition: filter 120ms ease;
            }
            .nav-btn:hover {
                filter: brightness(0.9);
            }
            .nav-btn:focus-visible {
                outline: 3px solid var(--text);
                outline-offset: 3px;
            }

            /* ── Main ───────────────────────────────────────── */

            main {
                flex: 1;
                max-width: 900px;
                width: 100%;
                margin-inline: auto;
                padding-top: var(--nav-h);
            }

            /* ── Hero (home page) ───────────────────────────── */

            .hero {
                position: relative;
                padding-left: var(--edge);
                padding-top: clamp(3rem, 8vw, 5rem);
                margin-bottom: clamp(2rem, 7vw, 3.5rem);
            }

            .hero-kicker {
                font-size: 0.6875rem;
                font-weight: 500;
                letter-spacing: 0.15em;
                text-transform: uppercase;
                color: var(--muted);
                margin-bottom: 0.875rem;
            }

            h1 {
                font-family: "Fraunces", Georgia, serif;
                font-size: clamp(3.25rem, 11vw, 6rem);
                font-weight: 800;
                line-height: 0.98;
                letter-spacing: -0.03em;
                font-optical-sizing: auto;
                font-variation-settings:
                    "SOFT" 50,
                    "WONK" 1;
                position: relative;
                z-index: 1;
            }

            .raccoon {
                position: absolute;
                z-index: 0;
                right: var(--edge);
                top: 85%;
                transform: translateY(-50%) rotate(-20deg);
                width: clamp(100px, 26vw, 148px);
                height: auto;
                pointer-events: none;
                user-select: none;
                opacity: 0.88;
            }

            @media (max-width: 380px) {
                .raccoon {
                    width: 100px;
                }
            }

            /* ── Next Cleanup grid ──────────────────────────── */

            .cleanup {
                display: grid;
                grid-template-columns: auto auto 1fr;
                column-gap: 0.5rem;
                row-gap: 0.4rem;
                width: fit-content;
                max-width: calc(100% - var(--edge) * 2);
                margin-inline: auto;
                align-items: center;
                text-align: left;
                margin-bottom: clamp(1.5rem, 5vw, 2.5rem);
            }

            .cleanup .span {
                grid-column: 2 / 4;
            }

            .cleanup .icon-cell {
                width: 18px;
                height: 18px;
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--muted);
                flex-shrink: 0;
            }
            .cleanup .icon-cell svg {
                width: 100%;
                height: 100%;
            }

            .cleanup a.icon-cell {
                text-decoration: none;
                border-radius: 2px;
                transition: color 0.15s;
            }
            .cleanup a.icon-cell:hover {
                color: var(--brand);
            }
            .cleanup a.icon-cell:focus-visible {
                outline: 2px solid var(--accent);
                outline-offset: 3px;
            }

            /* Conversational sentence — sentence case, wraps gracefully */
            .cleanup-countdown {
                font-size: 0.9375rem;
                font-weight: 400;
                line-height: 1.5;
                color: var(--muted);
            }

            .cleanup-key {
                font-size: 0.9375rem;
                font-weight: 600;
                white-space: nowrap;
            }

            .cleanup-val {
                font-size: 0.9375rem;
                line-height: 1.4;
            }

            .cleanup-val a {
                color: var(--text);
                text-decoration: underline;
                text-decoration-thickness: 1px;
                text-underline-offset: 3px;
                text-decoration-color: rgba(245, 244, 238, 0.25);
            }
            .cleanup-val a:hover {
                text-decoration-color: var(--text);
            }
            .cleanup-val a:focus-visible {
                outline: 2px solid var(--accent);
                outline-offset: 2px;
                border-radius: 2px;
            }

            .cleanup-reassurance {
                font-size: 0.9375rem;
                color: var(--muted);
            }

            /* ── CTA buttons (95vw, stacked) ────────────────── */

            .cta-actions {
                width: 95vw;
                margin-left: calc(50% - 47.5vw);
                display: flex;
                flex-direction: column;
                gap: 0.75rem;
                margin-bottom: clamp(2rem, 7vw, 3rem);
            }

            .cta-primary {
                display: block;
                text-align: center;
                padding: 1.1rem 1.5rem;
                font-family: "Hanken Grotesk", system-ui, sans-serif;
                font-size: clamp(1rem, 2vw, 1.25rem);
                font-weight: 600;
                color: var(--bg);
                background: var(--btn-light);
                text-decoration: none;
                border-radius: var(--hover-radius);
                transition: opacity 120ms ease;
            }
            .cta-primary:hover {
                opacity: 0.92;
            }
            .cta-primary:focus-visible {
                outline: 2px solid var(--brand);
                outline-offset: 3px;
            }

            .cta-secondary {
                display: block;
                text-align: center;
                padding: 1.1rem 1.5rem;
                font-family: "Hanken Grotesk", system-ui, sans-serif;
                font-size: clamp(1rem, 2vw, 1.25rem);
                font-weight: 600;
                color: var(--text);
                background: rgba(255, 255, 255, 0.06);
                border: 1px solid var(--line);
                text-decoration: none;
                border-radius: var(--hover-radius);
                transition: background-color 120ms ease;
            }
            .cta-secondary:hover {
                background: rgba(255, 255, 255, 0.10);
            }
            .cta-secondary:focus-visible {
                outline: 2px solid var(--brand);
                outline-offset: 3px;
            }

            /* ── Why volunteer (Config 3-col grid) ──────────── */

            .why {
                width: 95vw;
                margin-left: calc(50% - 47.5vw);
                margin-bottom: clamp(2rem, 7vw, 3rem);
            }

            .why__label {
                font-size: 0.6875rem;
                font-weight: 600;
                letter-spacing: 0.15em;
                text-transform: uppercase;
                color: var(--muted);
                margin-bottom: 0.75rem;
                padding-left: clamp(1rem, 2.5vw, 1.5rem);
            }

            .why__label::before {
                content: "▪ ";
            }

            .why__grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                border-top: 1px solid var(--line);
                border-bottom: 1px solid var(--line);
            }

            .why__col {
                padding: 2rem clamp(1rem, 2.5vw, 1.5rem);
            }

            .why__col + .why__col {
                border-left: 1px solid var(--line);
            }

            .why__col h3 {
                font-family: "Fraunces", Georgia, serif;
                font-size: clamp(1.4rem, 3vw, 2rem);
                font-weight: 600;
                font-optical-sizing: auto;
                font-variation-settings:
                    "SOFT" 50,
                    "WONK" 1;
                line-height: 1.1;
                margin-bottom: 0.75rem;
            }

            .why__col p {
                font-size: 0.9375rem;
                line-height: 1.6;
                color: var(--muted);
            }

            @media (max-width: 760px) {
                .why__grid {
                    grid-template-columns: 1fr;
                }
                .why__col + .why__col {
                    border-left: none;
                    border-top: 1px solid var(--line);
                }
            }

            /* ── Subscribe (iframe) ─────────────────────────── */

            .subscribe {
                text-align: center;
                margin-bottom: clamp(2rem, 7vw, 3rem);
            }

            .subscribe-copy {
                font-size: 1rem;
                line-height: 1.55;
                max-width: 36ch;
                margin-inline: auto;
                margin-bottom: 0.875rem;
            }

            .iframe-wrap {
                width: min(480px, 100%);
                margin-inline: auto;
                border-radius: 8px;
                overflow: hidden;
                box-shadow: 0 2px 20px rgba(0, 0, 0, 0.35);
            }

            .iframe-wrap iframe {
                display: block;
                width: 100%;
            }

            /* ── /join page ─────────────────────────────────── */

            .join-page {
                padding-inline: var(--edge);
                padding-bottom: clamp(2rem, 7vw, 3rem);
            }

            .join-page h1 {
                margin-bottom: 0.75rem;
            }

            .join-sub {
                font-size: 1.0625rem;
                line-height: 1.55;
                color: var(--muted);
                margin-bottom: clamp(1.5rem, 5vw, 2.5rem);
            }

            .join-reassurance {
                font-size: 1rem;
                font-weight: 600;
                margin-top: 0.75rem;
                margin-bottom: clamp(2rem, 7vw, 3rem);
            }

            .back-link {
                font-size: 0.9375rem;
                color: var(--muted);
                text-decoration: underline;
                text-decoration-thickness: 1px;
                text-underline-offset: 3px;
                text-decoration-color: rgba(245, 244, 238, 0.25);
            }
            .back-link:hover {
                text-decoration-color: var(--text);
                color: var(--text);
            }
            .back-link:focus-visible {
                outline: 2px solid var(--accent);
                outline-offset: 2px;
                border-radius: 2px;
            }

            /* ── Stub pages ─────────────────────────────────── */

            .stub-page {
                padding: clamp(3rem, 8vw, 5rem) var(--edge)
                    clamp(2rem, 7vw, 3rem);
            }

            .stub-page h1 {
                margin-bottom: 1rem;
            }

            .stub-desc {
                color: var(--muted);
                margin-bottom: 2rem;
                font-size: 1.0625rem;
                line-height: 1.55;
            }

            /* ── Footer ─────────────────────────────────────── */

            .site-footer {
                border-top: 1px solid var(--line);
                margin-top: auto;
                padding-top: clamp(2rem, 5vw, 3rem);
            }

            .footer-grid {
                max-width: 900px;
                margin-inline: auto;
                padding: 0 var(--edge) var(--edge);
                display: grid;
                grid-template-columns: auto auto 1fr;
                gap: clamp(1.5rem, 5vw, 3rem);
                align-items: start;
            }

            .footer-col {
                display: flex;
                flex-direction: column;
                gap: 0.625rem;
            }

            /*
             * Padding reserved at rest so highlight doesn't reflow on hover.
             * Negative margin-inline cancels the indent so resting text stays
             * column-aligned.
             */
            .footer-col a {
                font-size: 0.6875rem;
                font-weight: 600;
                letter-spacing: 0.12em;
                text-transform: uppercase;
                color: var(--muted);
                text-decoration: none;
                border-radius: var(--hover-radius);
                padding: 0.25rem 0.5rem;
                margin-inline: -0.5rem;
                transition: background-color 120ms ease, color 120ms ease;
            }
            .footer-col a:hover,
            .footer-col a:focus-visible {
                background: var(--accent);
                color: var(--bg);
                outline: none;
            }

            .footer-right {
                text-align: right;
                display: flex;
                flex-direction: column;
                align-items: flex-end;
                gap: 0.625rem;
            }

            .footer-right a {
                font-size: 0.6875rem;
                font-weight: 600;
                letter-spacing: 0.12em;
                text-transform: uppercase;
                color: var(--muted);
                text-decoration: none;
                border-radius: var(--hover-radius);
                padding: 0.25rem 0.5rem;
                margin-inline: -0.5rem;
                transition: background-color 120ms ease, color 120ms ease;
            }
            .footer-right a:hover,
            .footer-right a:focus-visible {
                background: var(--accent);
                color: var(--bg);
                outline: none;
            }

            .footer-copyright {
                font-size: 0.6875rem;
                font-weight: 600;
                letter-spacing: 0.12em;
                text-transform: uppercase;
                color: var(--text);
                opacity: 0.3;
            }

            @media (max-width: 600px) {
                .footer-grid {
                    grid-template-columns: 1fr;
                    gap: 1.5rem;
                }
                .footer-right {
                    text-align: left;
                    align-items: flex-start;
                }
            }
        </style>
    </head>

    <body>
        <!--
          .ticker-bar: full-bleed sticky — keeps --bg visible in the side gutters
          so scrolling page content never peeks through as it passes under the bar.
          .ticker: the visible 95vw bar with the bottom divider.
        -->
        <div class="ticker-bar">
            <div class="ticker" id="ticker">
                <div class="ticker__viewport">
                    <div class="ticker__track">
                        <!--
                          Two identical segments. padding-right creates the pitch (~55vw).
                          Resting: translateX(-50%) = start of segment 2.
                          Animation: –50% → 0 (rightward, seamless loop).
                        -->
                        <span class="ticker__segment">{TICKER_TEXT}</span>
                        <span class="ticker__segment" aria-hidden="true"
                            >{TICKER_TEXT}</span
                        >
                    </div>
                </div>
                <!-- Control on the right, outside the scrolling area -->
                <button
                    class="ticker__toggle"
                    id="ticker-toggle"
                    type="button"
                    aria-pressed="false"
                    aria-label="Play stats ticker"
                >
                    <!-- play-circle (shown when paused) -->
                    <svg
                        class="ticker__icon ticker__icon--play"
                        width="22"
                        height="22"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        aria-hidden="true"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"></path>
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M15.91 11.672a.375.375 0 0 1 0 .656l-5.603 3.113a.375.375 0 0 1-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112Z"
                        ></path>
                    </svg>
                    <!-- pause-circle (shown when playing) -->
                    <svg
                        class="ticker__icon ticker__icon--pause"
                        width="22"
                        height="22"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        aria-hidden="true"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M14.25 9v6m-4.5 0V9M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"
                        ></path>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Fixed scroll-aware nav: logo left | ABOUT · FAQ · JOIN US right -->
        <nav class="nav" id="main-nav" aria-label="Site navigation">
            <a
                href="/"
                class="nav-home"
                aria-label="Community Cleanup PLG — home"
            >
                <div class="logo-mark" aria-hidden="true"></div>
            </a>
            <div class="nav-links">
                <a href="/about" class="nav-link">About</a>
                <a href="/faq" class="nav-link">FAQ</a>
                <a href="/join" class="nav-btn">Join us</a>
            </div>
        </nav>

        <main>
            <slot />
        </main>

        <footer class="site-footer">
            <div class="footer-grid">
                <div class="footer-col">
                    <a href="/join">Join us</a>
                    <a href="/faq">FAQ</a>
                    <a href="/about">About</a>
                    <a href="/community-agreements">Community agreements</a>
                </div>
                <div class="footer-col">
                    <a
                        href="https://discord.com/invite/H9her7r8N2"
                        target="_blank"
                        rel="noopener noreferrer">Discord</a
                    >
                    <a href="mailto:communitycleanupplg@gmail.com">Email us</a>
                    <a
                        href="https://communitycleanupplg.substack.com/subscribe"
                        target="_blank"
                        rel="noopener noreferrer">Substack</a
                    >
                    <a
                        href="https://www.instagram.com/communitycleanupplg/"
                        target="_blank"
                        rel="noopener noreferrer">Instagram</a
                    >
                    <a
                        href="https://www.amazon.com/registries/gl/guest-view/1Y3YRXM9ILG5I"
                        target="_blank"
                        rel="noopener noreferrer">Support us</a
                    >
                </div>
                <div class="footer-right">
                    <a href="/terms">Volunteering Terms</a>
                    <p class="footer-copyright">
                        &copy; Community Cleanup PLG 2026
                    </p>
                </div>
            </div>
        </footer>

        <script>
            // ── Ticker ──────────────────────────────────────────
            const ticker = document.getElementById("ticker")!;
            const tickerToggle = document.getElementById("ticker-toggle")!;

            // Autoplay on load — only if user has no motion preference
            if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
                ticker.classList.add("is-playing");
                tickerToggle.setAttribute("aria-pressed", "true");
                tickerToggle.setAttribute("aria-label", "Pause stats ticker");
            }

            tickerToggle.addEventListener("click", () => {
                const playing = ticker.classList.toggle("is-playing");
                tickerToggle.setAttribute("aria-pressed", String(playing));
                tickerToggle.setAttribute(
                    "aria-label",
                    playing ? "Pause stats ticker" : "Play stats ticker",
                );
            });

            // ── Scroll-aware nav ────────────────────────────────
            const nav = document.getElementById("main-nav")!;
            let lastY = 0;
            let ticking = false;
            window.addEventListener(
                "scroll",
                () => {
                    if (!ticking) {
                        requestAnimationFrame(() => {
                            const y = window.scrollY;
                            if (y < 80) {
                                nav.classList.remove(
                                    "nav--hidden",
                                    "nav--solid",
                                );
                            } else if (y > lastY) {
                                nav.classList.add("nav--hidden");
                            } else {
                                nav.classList.remove("nav--hidden");
                                nav.classList.add("nav--solid");
                            }
                            lastY = y;
                            ticking = false;
                        });
                        ticking = true;
                    }
                },
                { passive: true },
            );
        </script>
    </body>
</html>
