---
import Base from "../layouts/Base.astro";
import {
    CLEANUP_ISO,
    CLEANUP_TIME,
    CLEANUP_CORNER,
    CLEANUP_MAPS_URL,
} from "../data/event";
import { getCountdown } from "../data/countdown";

const cleanupDate = new Date(CLEANUP_ISO);
const state = getCountdown(new Date());

const countdownLine =
    state.tag === "past"         ? ""
    : state.tag === "now"        ? "Is happening right now!"
    : state.tag === "minutes"    ? `Is starting in ${state.n} minute${state.n === 1 ? "" : "s"}!`
    : state.tag === "hours"      ? `Is starting in ${state.n} hour${state.n === 1 ? "" : "s"}!`
    : state.tag === "tomorrow"   ? "Is tomorrow!"
    : state.tag === "this-weekend"  ? `Is this ${state.dayName}!`
    : state.tag === "next-weekend"  ? `Is next ${state.dayName}.`
    : `That's in ${state.word} days.`;

const joinDisplayDate = new Intl.DateTimeFormat("en-US", {
    timeZone: "America/New_York",
    weekday: "long",
    month: "long",
    day: "numeric",
    year: "numeric",
}).format(cleanupDate);
---

<Base
    title="Volunteer with Community Cleanup PLG"
    description="There's no registration — just show up. Here's where and when."
    navMode="static"
>
    <div class="join-page">
        <h1>Our next cleanup</h1>
        {countdownLine && <p class="join-countdown">{countdownLine}</p>}
        <p class="join-sub">No registration, and we'll provide the supplies—just show up. Look for the shopping cart with our trash grabbers in it.</p>

        <div class="join-details">
            <div class="join-detail">
                <p class="join-detail-label">When</p>
                <p class="join-detail-value">
                    {joinDisplayDate}<br />{CLEANUP_TIME}
                </p>
            </div>
            <div class="join-detail">
                <p class="join-detail-label">Where</p>
                <p class="join-detail-value">
                    <a
                        href={CLEANUP_MAPS_URL}
                        target="_blank"
                        rel="noopener noreferrer">{CLEANUP_CORNER}</a>
                <p>Prospect Lefferts Gardens<br />Brooklyn, New York</p>
            </div>
        </div>
        <img
            src="/images/cart.webp"
            alt=""
            class="join-cart"
            aria-hidden="true"
            width="640"
            height="634"
        />
    </div>
</Base>
