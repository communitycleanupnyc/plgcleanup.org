---
import Base from "../layouts/Base.astro";
import Carousel from "../components/Carousel.astro";
import type { CarouselItem } from "../components/carousel.types";
import { testimonials } from "../data/testimonials";
import type { ImageMetadata } from "astro";
import { VOLUNTEER_COUNT } from "../data/event";
import { getCountdown } from "../data/countdown";

const files = import.meta.glob<{ default: ImageMetadata }>(
    "../assets/testimonials/*.{jpg,jpeg,png,webp}",
    { eager: true },
);

const items: CarouselItem[] = testimonials.map((t) => {
    const mod = files[`../assets/testimonials/${t.file}`];
    if (!mod)
        throw new Error(
            `[testimonials] No image for "${t.file}" referenced in testimonials.ts`,
        );
    return { ...t, img: mod.default };
});

// Fail loudly if an image file has no matching data entry
const knownFiles = new Set(testimonials.map((t) => t.file));
for (const path of Object.keys(files)) {
    const file = path.split("/").pop()!;
    if (!knownFiles.has(file))
        throw new Error(
            `[testimonials] Image "${file}" has no entry in testimonials.ts`,
        );
}

const state  = getCountdown(new Date());
const SUFFIX = ". Want to see why people love volunteering with us?";

const countdownSentence =
    state.tag === "past"
        ? `Each cleanup is only an hour${SUFFIX}`
    : state.tag === "now"
        ? `The next cleanup is <a href="/join">happening right now</a>${SUFFIX}`
    : state.tag === "minutes"
        ? `The next cleanup is in <a href="/join">${state.n} minute${state.n === 1 ? "" : "s"}</a>${SUFFIX}`
    : state.tag === "hours"
        ? `The next cleanup is in <a href="/join">${state.n} hour${state.n === 1 ? "" : "s"}</a>${SUFFIX}`
    : state.tag === "tomorrow"
        ? `The next cleanup is <a href="/join">tomorrow</a>${SUFFIX}`
    : state.tag === "this-weekend"
        ? `The next cleanup is <a href="/join">this ${state.dayName}</a>${SUFFIX}`
    : state.tag === "next-weekend"
        ? `The next cleanup is <a href="/join">next ${state.dayName}</a>${SUFFIX}`
    : `The next cleanup is in <a href="/join">${state.word} days</a>${SUFFIX}`;
---

<Base>
    <div class="hero">
        <h1>Clean Prospect Lefferts Gardens.</h1>
        <img
            src="/images/raccoon.webp"
            alt=""
            class="raccoon"
            aria-hidden="true"
            width="148"
            height="121"
        />
    </div>

    <div class="hero-body">
        <p>
            {VOLUNTEER_COUNT} of your neighbors are helping keep trash off our streets.
        </p>
        <p set:html={countdownSentence} />
    </div>

    <div class="cta-actions">
        <a class="cta-primary" href="/join">Join us this weekend</a>
        <a class="cta-secondary" href="/schedule">View schedule</a>
    </div>

    <section class="why" aria-labelledby="why-label">
        <p class="why__label" id="why-label">Why volunteer</p>
        <div class="why__grid">
            <div class="why__col">
                <h3>Really, picking up trash?</h3>
                <p>
                    Every piece counts, down to a cigarette butt. Simply being visible inspires others to help our community. Bonus: volunteering has "<a
                        href="https://pmc.ncbi.nlm.nih.gov/articles/PMC10159229/" title="Cambridge University Press (2026)"
                        >significant positive effects... on social, physical, and mental health.</a>"
                </p>
            </div>
            <div class="why__col">
                <h3>What to expect</h3>
                <p>
                    Just bring yourself! And water if it's hot out. We'll provide you with gloves, a grabber, and a bag. You'll find a
                    stretch of sidewalk, and an hour later it's transformed.
                    Optional crew shot at the end.
                </p>
            </div>
            <div class="why__col">
                <h3>Who you'll meet</h3>
                <p>
                    Around 5 to 10 fellow volunteers, including your squad lead(s). These
                    are your neighbors and they rock. Chat, or
                    lock in and savor the rhythmic process of sanitation.
                </p>
            </div>
        </div>
    </section>

    <Carousel items={items} variant="natural" heading="Why trash club" />
</Base>
