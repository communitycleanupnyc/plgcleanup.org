---
import Base from "../layouts/Base.astro";
import {
    CLEANUP_ISO,
    CLEANUP_TIME,
    CLEANUP_CORNER,
    CLEANUP_MAPS_URL,
    CLEANUP_CALENDAR_URL,
    SUBSCRIBER_COUNT,
    etDateParts,
    VOLUNTEER_COUNT,
} from "../data/event";

const cleanupDate = new Date(CLEANUP_ISO);
const now = new Date();
const todayET = etDateParts(now);

const SEASONS = [
    "Winter",
    "Winter",
    "Spring",
    "Spring",
    "Spring",
    "Summer",
    "Summer",
    "Summer",
    "Autumn",
    "Autumn",
    "Autumn",
    "Winter",
];
const seasonLabel = `${SEASONS[todayET.m - 1]} ${todayET.y}`;
const cleanupET = etDateParts(cleanupDate);

// Whole-day diff using UTC midnight to dodge DST
const todayMs = Date.UTC(todayET.y, todayET.m - 1, todayET.day);
const cleanupMs = Date.UTC(cleanupET.y, cleanupET.m - 1, cleanupET.day);
const N = Math.round((cleanupMs - todayMs) / 86_400_000);

const NUMBER_WORDS = ["zero","one","two","three","four","five","six","seven","eight","nine"];
const nWord = N >= 0 && N < 10 ? NUMBER_WORDS[N] : String(N);
const nLabel = `<mark>${nWord} day${N === 1 ? "" : "s"} away</mark>`;

const countdownSentence =
    N >= 1
        ? `The next cleanup is only ${nLabel}, and each cleanup is only an hour. Want to see why people love volunteering with us?`
        : N === 0
          ? `The next cleanup is <mark>today</mark> — and it's only an hour. Want to see why people love volunteering with us?`
          : "Each cleanup is only an hour. Want to see why people love volunteering with us?";

// "This Saturday / Next Saturday / Saturday" for the When line
const todayDow = new Date(todayMs).getUTCDay(); // 0=Sun 6=Sat
const daysToThisSat = (6 - todayDow + 7) % 7;
const thisSatMs = todayMs + daysToThisSat * 86_400_000;
const nextSatMs = thisSatMs + 7 * 86_400_000;

const cleanupDisplayDate = new Intl.DateTimeFormat("en-US", {
    timeZone: "America/New_York",
    month: "long",
    day: "numeric",
}).format(cleanupDate); // "June 20"

let whenPhrase: string;
if (cleanupMs === thisSatMs) {
    whenPhrase = `${CLEANUP_TIME} this Saturday, ${cleanupDisplayDate}`;
} else if (cleanupMs === nextSatMs) {
    whenPhrase = `${CLEANUP_TIME} next Saturday, ${cleanupDisplayDate}`;
} else {
    whenPhrase = `${CLEANUP_TIME} Saturday, ${cleanupDisplayDate}`;
}
---

<Base>
    <div class="hero">
        <h1>Help clean up Prospect&nbsp;Lefferts Gardens.</h1>
        <img
            src="/images/raccoon.webp"
            alt=""
            class="raccoon"
            aria-hidden="true"
            width="148"
            height="121"
        />
    </div>

    <div class="hero-body">
        <p>
            Since 2023, {VOLUNTEER_COUNT} of your neighbors have been helping clean
            up our streets with Community Cleanup PLG.
        </p>
        <p set:html={countdownSentence}></p>
    </div>

    <div class="cta-actions">
        <a class="cta-primary" href="/join">Join us this weekend</a>
        <a class="cta-secondary" href="/schedule">View schedule</a>
    </div>

    <section class="why" aria-labelledby="why-label">
        <p class="why__label" id="why-label">Why volunteer</p>
        <div class="why__grid">
            <div class="why__col">
                <h3>Why this is awesome!</h3>
                <p>
                    Every piece of trash counts. And when people see us on the
                    streets, they are inspired to help. Besides, volunteering
                    itself helps you: there are "significant positive effects of
                    volunteering on social, physical and mental health"(<a
                        href="https://pmc.ncbi.nlm.nih.gov/articles/PMC10159229/"
                        >Cambridge University Press</a
                    >).
                </p>
            </div>
            <div class="why__col">
                <h3>What to expect</h3>
                <p>
                    [placeholder] Grab a picker and a bag, we point you at a
                    stretch of sidewalk, and an hour later it's transformed.
                    Replace.
                </p>
            </div>
            <div class="why__col">
                <h3>Who you'll meet</h3>
                <p>
                    We usually have around 5–10 volunteers at every event. These
                    are your neighbors, and they are awesome. You're welcome to
                    chat or lock in and do your own thing. Over {
                        VOLUNTEER_COUNT
                    } of our neighbors have volunteered so far.
                </p>
            </div>
        </div>
    </section>
</Base>
