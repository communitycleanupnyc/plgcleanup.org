---
import Base from "../layouts/Base.astro";
import Carousel from "../components/Carousel.astro";
import type { CarouselItem } from "../components/carousel.types";
import { getCollection, render } from "astro:content";
import { VOLUNTEER_COUNT } from "../data/stats";
import { CLEANUP_ISO, CLEANUP_END_ISO } from "../data/event";
import { computeCountdown, renderHomeCountdown, renderCtaLabel } from "../data/countdown";
import { RANDOMIZE_TESTIMONIALS } from "../config";

// Fisher–Yates: a uniform random permutation (a fresh copy, doesn't mutate input).
function shuffle<T>(items: readonly T[]): T[] {
  const a = [...items];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

// Testimonials come from src/content/testimonials/*.md (see src/content.config.ts).
// The image() schema validates every photo at build time, so a missing or
// misnamed image fails the build loudly — no hand-rolled checks needed.
// Order is the `order` field by default; RANDOMIZE_TESTIMONIALS (src/config.ts)
// shuffles them fresh on every build instead.
const testimonials = await getCollection("testimonials");
const entries = RANDOMIZE_TESTIMONIALS
  ? shuffle(testimonials)
  : testimonials.sort((a, b) => a.data.order - b.data.order);

// The schema can't see the Markdown body, so guard it here: a blank testimonial
// would render an empty reveal panel. Fail the build loudly instead.
for (const entry of entries) {
  if (!entry.body?.trim()) {
    throw new Error(`[testimonials] "${entry.id}.md" has an empty body. Add the testimonial text.`);
  }
}

const items: CarouselItem[] = await Promise.all(
  entries.map(async (entry) => {
    const { Content } = await render(entry);
    return {
      img: entry.data.image,
      name: entry.data.name,
      quote: entry.data.quote,
      alt: entry.data.alt,
      focusPosition: entry.data.focusPosition,
      Body: Content,
    };
  }),
);

// Countdown copy is rendered at build time here and recomputed on load by
// ../lib/countdown.client.ts (imported below) so it never goes stale.
const state = computeCountdown(new Date(), CLEANUP_ISO, CLEANUP_END_ISO);
const countdownSentence = renderHomeCountdown(state);
const ctaLabel = renderCtaLabel(state);
---

<Base title="Volunteer Trash Cleanup in Prospect Lefferts Gardens">
  <div class="hero">
    <h1>Clean Prospect Lefferts Gardens.</h1>
    <img
      src="/images/raccoon.webp"
      alt=""
      class="raccoon"
      aria-hidden="true"
      width="148"
      height="121"
    />
  </div>

  <div class="hero-body">
    <p>
      {VOLUNTEER_COUNT} of your neighbors are helping keep trash off our streets.
    </p>
    <p
      data-countdown
      data-variant="home"
      data-start={CLEANUP_ISO}
      data-end={CLEANUP_END_ISO}
      set:html={countdownSentence}
    />
  </div>

  <div class="cta-actions">
    <a
      class="cta-primary"
      href="/join"
      data-countdown
      data-variant="cta"
      data-start={CLEANUP_ISO}
      data-end={CLEANUP_END_ISO}>{ctaLabel}</a
    >
    <a class="cta-secondary" href="/schedule">View schedule</a>
  </div>

  <section class="why" aria-labelledby="why-label">
    <p class="why__label" id="why-label">Why volunteer</p>
    <div class="why__grid">
      <div class="why__col">
        <h3>Really, picking up trash?</h3>
        <p>
          Every piece counts, down to a cigarette butt. Simply being visible inspires others to help
          our community. Bonus: volunteering has "<a
            href="https://pmc.ncbi.nlm.nih.gov/articles/PMC10159229/"
            title="Cambridge University Press (2026)"
            >significant positive effects... on social, physical, and mental health.</a
          >"
        </p>
      </div>
      <div class="why__col">
        <h3>What to expect</h3>
        <p>
          Just bring yourself! And water if it's hot out. We'll provide you with gloves, a grabber,
          and a bag. You'll find a stretch of sidewalk, and an hour later it's transformed. Optional
          crew shot at the end.
        </p>
      </div>
      <div class="why__col">
        <h3>Who you'll meet</h3>
        <p>
          Around 5 to 10 fellow volunteers, including your squad lead(s). These are your neighbors
          and they rock. Chat, or lock in to savor the rhythmic process of sanitation.
        </p>
      </div>
    </div>
  </section>

  <Carousel items={items} variant="natural" heading="Why trash club" />
</Base>

<script>
  import "../lib/countdown.client.ts";
</script>

<style>
  /* Home page (hero, hero body, why-volunteer grid). */
  .hero {
    position: relative;
    width: var(--site-w);
    margin-left: var(--site-ml);
    padding-top: clamp(3rem, 8vw, 5rem);
    margin-bottom: clamp(10rem, 7vw, 3.5rem);
  }

  .hero-kicker {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.875rem;
  }

  /* Hero h1 is much larger; z-index lifts it above the raccoon */
  .hero h1 {
    font-size: clamp(3.25rem, 11vw, 6rem);
    position: relative;
    z-index: 1;
  }

  .raccoon {
    position: absolute;
    z-index: 0;
    right: var(--edge);
    top: 110%;
    transform: translateY(-25%) rotate(-20deg);
    width: clamp(100px, 26vw, 148px);
    height: auto;
    pointer-events: none;
    user-select: none;
    opacity: 0.88;
  }

  @media (max-width: 380px) {
    .raccoon {
      width: 100px;
    }
  }

  /* ── Hero body (below h1, above CTA) ───────────── */

  .hero-body {
    width: var(--site-w);
    margin-left: var(--site-ml);
    /*padding-left: var(--edge);*/
    padding-right: var(--edge);
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin-bottom: clamp(2rem, 6vw, 3rem);
  }

  .hero-body p {
    line-height: 1.4;
    color: var(--text);
    font-weight: 400;
    letter-spacing: -0.005em;
    max-width: 70ch;
  }

  .hero-body p:first-child {
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    line-height: 1.25;
    margin-bottom: 1rem;
  }

  .hero-body p:last-child {
    font-size: clamp(1.5rem, 2.25vw, 1.75rem);
    font-weight: 200;
    letter-spacing: 0em;
  }

  /* ── Why volunteer (Config 3-col grid) ──────────── */

  .why {
    width: var(--site-w);
    margin-left: var(--site-ml);
    margin-bottom: clamp(2rem, 7vw, 3rem);
  }

  .why__label {
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text);
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .why__label::before {
    content: "";
    display: block;
    flex-shrink: 0;
    width: 1.25rem;
    height: 0.75rem;
    background: var(--text);
  }

  .why__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1.5px solid var(--line);
    border-bottom: 1.5px solid var(--line);
  }

  .why__col {
    padding-block: 2rem;
  }

  /* Right padding on every col except last — gap before the divider */
  .why__col:not(:last-child) {
    padding-right: clamp(0rem, 2.5vw, 1.5rem);
  }

  /* Left padding + divider on col 2 and col 3 */
  .why__col + .why__col {
    border-left: 1.5px solid var(--line);
    padding-left: clamp(1rem, 2.5vw, 1.5rem);
  }

  .why__col h3 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw, 2rem);
    font-weight: 300;
    letter-spacing: -0.03em;
    font-optical-sizing: auto;
    font-variation-settings:
      "SOFT" 50,
      "WONK" 0;
    line-height: 1.1;
    margin-bottom: 0.75rem;
  }

  .why__col p {
    font-size: 1.2rem;
    line-height: 1.6;
    font-weight: 300;
    color: var(--text);
  }

  @media (max-width: 760px) {
    .why__grid {
      grid-template-columns: 1fr;
    }
    .why__col + .why__col {
      border-left: none;
      border-top: 1.5px solid var(--line);
      padding-left: 0;
    }
    .why__col:not(:last-child) {
      padding-right: 0;
    }
  }
</style>
